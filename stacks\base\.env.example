# =============================================================================
# Base Stack — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────

# Your base domain (all services become <service>.<DOMAIN>)
DOMAIN=example.com

# Timezone  (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Asia/Shanghai

# ── Traefik / ACME ───────────────────────────────────────────────────────────

# Email address used for Let's Encrypt registration
ACME_EMAIL=admin@example.com

# Certificate resolver to use: letsencrypt | letsencrypt-staging | letsencrypt-dns
# Use "letsencrypt-staging" first to avoid rate limits while testing
CERT_RESOLVER=letsencrypt

# Traefik dashboard Basic Auth  (generate with: htpasswd -nB admin)
# Example: admin:$$2y$$05$$...   (escape $ with $$ in .env files)
TRAEFIK_AUTH=admin:$$apr1$$xyz$$REPLACE_ME

# ── DNS Challenge (optional — needed for wildcard certs) ─────────────────────
# Uncomment the block matching your DNS provider.

# Cloudflare
# CF_DNS_API_TOKEN=your_cloudflare_api_token

# Alibaba Cloud (ALICLOUD / alidns)
# ALICLOUD_ACCESS_KEY=your_access_key
# ALICLOUD_SECRET_KEY=your_secret_key

# ── Watchtower Notifications ──────────────────────────────────────────────────
# Shoutrrr notification URL — see https://containrrr.dev/shoutrrr/
# Examples:
#   ntfy:    generic+https://ntfy.sh/my-topic
#   Gotify:  gotify://gotify.example.com/TOKEN
#   Slack:   slack://TOKEN@workspace/channel
WATCHTOWER_NOTIFICATIONS=shoutrrr
WATCHTOWER_NOTIFICATION_URL=

# ── Docker Socket Proxy (internal — no need to change) ───────────────────────
SOCKET_PROXY_HOST=socket-proxy
SOCKET_PROXY_PORT=2375
