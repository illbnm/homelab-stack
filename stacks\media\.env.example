# =============================================================================
# Media Stack — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# Your base domain (services will be accessible at <service>.<DOMAIN>)
DOMAIN=example.com

# Timezone (TZ database name)
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Shanghai

# User ID and Group ID for file permissions
# Run `id` on your host to get your UID/GID
PUID=1000
PGID=1000

# Traefik certificate resolver name (must match your Traefik config)
CERT_RESOLVER=letsencrypt

# -----------------------------------------------------------------------------
# Data Directories (TRaSH Guides hardlink layout)
# -----------------------------------------------------------------------------
# IMPORTANT: Both paths MUST be on the same filesystem for hardlinks to work!
#
# Host directory layout:
#   /data/
#   ├── torrents/
#   │   ├── movies/      ← qBittorrent downloads movies here
#   │   └── tv/          ← qBittorrent downloads TV here
#   └── media/
#       ├── movies/      ← Radarr hardlinks movies here  → Jellyfin reads
#       └── tv/          ← Sonarr hardlinks TV here      → Jellyfin reads

# Root path for organised media (movies, tv)
MEDIA_ROOT=/data/media

# Root path for torrent downloads (movies, tv)
DOWNLOADS_ROOT=/data/torrents

# -----------------------------------------------------------------------------
# qBittorrent
# -----------------------------------------------------------------------------

# BitTorrent listening port (also open this port in your firewall/router)
QBITTORRENT_PORT=6881

# qBittorrent Web UI credentials
# The default username is "admin"; password is auto-generated on first start
# and printed in the container logs: docker logs qbittorrent | grep password
QBITTORRENT_USER=admin
QBITTORRENT_PASS=changeme_strong_password

# -----------------------------------------------------------------------------
# Jellyseerr
# -----------------------------------------------------------------------------

# Log level: debug | info | warn | error
JELLYSEERR_LOG_LEVEL=info
