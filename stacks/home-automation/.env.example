# Home Automation Stack — Environment Variables
# Copy to .env and fill required values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# --- Home Assistant ---
# No env vars needed — configured via web UI

# --- Node-RED ---
# No env vars needed — configured via web UI

# --- Mosquitto MQTT ---
# No env vars needed — see config/mosquitto/mosquitto.conf

# --- Zigbee2MQTT ---
# Zigbee adapter path (adjust for your hardware)
# Common: /dev/ttyUSB0 (CC2531), /dev/ttyACM0 (Sonoff Zigbee 3.0)
ZIGBEE_ADAPTER_PATH=/dev/ttyUSB0
