# =============================================================================
# Home Automation Stack Configuration
# =============================================================================

# Domain
DOMAIN=example.com

# Timezone
TZ=Asia/Shanghai

# Zigbee Device (check with: ls -la /dev/ttyUSB*)
ZIGBEE_DEVICE=/dev/ttyUSB0

# Mosquitto Authentication (recommended for production)
# Create with: mosquitto_passwd -c config/mosquitto/passwd <username>
MQTT_USER=
MQTT_PASSWORD=
