# =============================================================================
# Productivity Stack — Environment Variables
# Copy to .env and fill ALL values before running.
# Run: cp .env.example .env && nano .env
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
DOMAIN=yourdomain.com
TZ=Asia/Shanghai
PUID=1000
PGID=1000

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# -----------------------------------------------------------------------------
# SMTP CONFIGURATION (shared by Gitea, Vaultwarden)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_SECURITY=starttls

# -----------------------------------------------------------------------------
# DATABASE PASSWORDS (must match databases stack .env)
# -----------------------------------------------------------------------------
GITEA_DB_PASSWORD=
VAULTWARDEN_DB_PASSWORD=
OUTLINE_DB_PASSWORD=
BOOKSTACK_DB_PASSWORD=

# Redis password (must match databases stack .env)
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# GITEA SECRETS
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
GITEA_SECRET_KEY=
GITEA_INTERNAL_TOKEN=
GITEA_OAUTH2_JWT_SECRET=

# Gitea Runner token (get from Gitea UI: Site Admin > Actions > Runners)
GITEA_RUNNER_TOKEN=

# Gitea options
GITEA_MAILER_ENABLED=false
GITEA_MAIL_FROM=git@${DOMAIN}
GITEA_DISABLE_REGISTRATION=true
GITEA_REQUIRE_SIGNIN_VIEW=false
GITEA_OPENID_ENABLED=true
GITEA_OPENID_SIGNUP=false
GITEA_ACTIONS_ENABLED=true

# -----------------------------------------------------------------------------
# VAULTWARDEN SECRETS
# Generate admin token: openssl rand -base64 48
# -----------------------------------------------------------------------------
VAULTWARDEN_ADMIN_TOKEN=
VAULTWARDEN_SMTP_FROM=vaultwarden@${DOMAIN}
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_INVITATIONS_ALLOWED=true
# Optional: restrict signups to specific domains (comma-separated)
VAULTWARDEN_SIGNUP_DOMAINS=
VAULTWARDEN_ADMIN_RATELIMIT=300
VAULTWARDEN_ADMIN_BURST=3

# -----------------------------------------------------------------------------
# OUTLINE SECRETS
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
OUTLINE_SECRET_KEY=
OUTLINE_UTILS_SECRET=
OUTLINE_FILE_STORAGE=local

# Optional: S3/MinIO storage for Outline
# OUTLINE_S3_ACCESS_KEY=
# OUTLINE_S3_SECRET_KEY=
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# BOOKSTACK SECRETS
# Generate APP_KEY with: echo "base64:$(openssl rand -base64 32)"
# -----------------------------------------------------------------------------
BOOKSTACK_APP_KEY=
# Set to 'oidc' to enable SSO (requires OIDC vars below)
BOOKSTACK_AUTH_METHOD=standard

# -----------------------------------------------------------------------------
# STIRLING-PDF OPTIONS
# -----------------------------------------------------------------------------
STIRLING_SECURITY_ENABLED=false
STIRLING_ADMIN_USER=admin
STIRLING_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# OAUTH2 CLIENT CREDENTIALS
# Filled by scripts/setup-authentik.sh or manually from Authentik UI
# -----------------------------------------------------------------------------
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=
BOOKSTACK_OIDC_CLIENT_ID=
BOOKSTACK_OIDC_CLIENT_SECRET=
