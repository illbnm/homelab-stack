# ============================================================
# Productivity Stack — Environment Variables
# ============================================================
# Copy to .env and fill ALL values before running.
# ============================================================

# ─── Global ──────────────────────────────────────────────────
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# ─── Authentik SSO ───────────────────────────────────────────
AUTHENTIK_DOMAIN=auth.yourdomain.com

# ─── Gitea ───────────────────────────────────────────────────
GITEA_DB_PASSWORD=              # Must match databases stack
GITEA_OAUTH2_JWT_SECRET=        # openssl rand -hex 32
GITEA_RUNNER_TOKEN=             # Gitea Admin → Actions → Runners → Create
GITEA_SSH_PORT=2222             # Host port for SSH git clone

# ─── Vaultwarden ─────────────────────────────────────────────
VAULTWARDEN_ADMIN_TOKEN=        # openssl rand -base64 48

# ─── Outline ─────────────────────────────────────────────────
OUTLINE_SECRET_KEY=             # openssl rand -hex 32
OUTLINE_UTILS_SECRET=           # openssl rand -hex 32
OUTLINE_DB_PASSWORD=            # Must match databases stack

# ─── Shared Redis ────────────────────────────────────────────
REDIS_PASSWORD=                 # Must match databases stack

# ─── MinIO (from Storage Stack) ──────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── OAuth2 Credentials (from Authentik) ─────────────────────
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=

# ─── SMTP (optional — enables email notifications) ──────────
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
