# =============================================================================
# Productivity Stack — Environment Variables
# =============================================================================

TZ=Asia/Shanghai
DOMAIN=home.example.com
AUTHENTIK_DOMAIN=sso.home.example.com

# ----- Gitea -----
GITEA_DB_PASSWORD=changeme
# Generate JWT secret: openssl rand -hex 32
GITEA_OAUTH2_JWT_SECRET=changeme

# ----- Vaultwarden -----
VAULTWARDEN_ADMIN_TOKEN=changeme
VAULTWARDEN_DB_PASSWORD=changeme

# ----- Outline -----
OUTLINE_DB_PASSWORD=changeme
REDIS_PASSWORD=changeme
# Generate secrets: openssl rand -hex 32
OUTLINE_SECRET_KEY=changeme
OUTLINE_UTILS_SECRET=changeme
# Create Authentik OIDC app, then fill:
OUTLINE_OAUTH_CLIENT_ID=changeme
OUTLINE_OAUTH_CLIENT_SECRET=changeme

# ----- BookStack -----
BOOKSTACK_APP_KEY=changeme
BOOKSTACK_DB_PASSWORD=changeme
# Set to 'oidc' to enable SSO, 'standard' for local auth
BOOKSTACK_AUTH_METHOD=standard
BOOKSTACK_OIDC_CLIENT_ID=changeme
BOOKSTACK_OIDC_CLIENT_SECRET=changeme
