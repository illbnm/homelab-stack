# =============================================================================
# HomeLab Stack — Productivity Stack Environment Variables
# =============================================================================
# Prerequisites:
#   1. cp .env.example .env from repo root
#   2. Fill in all REQUIRED values below
#   3. Run: docker network create proxy && docker network create databases
#   4. Ensure databases stack (PostgreSQL + Redis + MariaDB) is running
#   5. Ensure SSO stack (Authentik) is running for OIDC authentication
#   6. Run: docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL (required from root .env)
# -----------------------------------------------------------------------------
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# AUTHENTIK SSO (required for OIDC)
# -----------------------------------------------------------------------------
AUTHENTIK_DOMAIN=auth.yourdomain.com

# -----------------------------------------------------------------------------
# DATABASE PASSWORDS (must match databases stack .env)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=           # Shared PostgreSQL master password
REDIS_PASSWORD=              # Shared Redis password
MARIADB_ROOT_PASSWORD=       # Shared MariaDB root password

# Per-service database passwords
GITEA_DB_PASSWORD=           # REQUIRED: strong random password
VAULTWARDEN_DB_PASSWORD=     # REQUIRED: strong random password
OUTLINE_DB_PASSWORD=         # REQUIRED: strong random password
BOOKSTACK_DB_PASSWORD=       # REQUIRED: strong random password

# -----------------------------------------------------------------------------
# SERVICE SECRETS (generate with: openssl rand -hex 32)
# -----------------------------------------------------------------------------
# Vaultwarden admin token (for admin panel access)
# Generate: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=

# Gitea OAuth2 JWT secret
# Generate: openssl rand -hex 32
GITEA_OAUTH2_JWT_SECRET=

# Outline secrets
# Generate: openssl rand -hex 32
OUTLINE_SECRET_KEY=
OUTLINE_UTILS_SECRET=

# BookStack app key
# Generate: echo "base64:$(openssl rand -base64 32)"
BOOKSTACK_APP_KEY=

# -----------------------------------------------------------------------------
# OAUTH2 / OIDC CLIENTS (filled by scripts/setup-authentik.sh)
# -----------------------------------------------------------------------------
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=
BOOKSTACK_OIDC_CLIENT_ID=
BOOKSTACK_OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# BOOKSTACK OPTIONS
# -----------------------------------------------------------------------------
# Set to 'oidc' to enable SSO (requires OIDC vars above)
BOOKSTACK_AUTH_METHOD=standard

# -----------------------------------------------------------------------------
# STIRLING PDF OPTIONS
# -----------------------------------------------------------------------------
# DOCKER_ENABLE_SECURITY=false (default) - no login required
# Set to true and configure for secure mode
