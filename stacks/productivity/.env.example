# =============================================================================
# Productivity Stack — Environment Variables
# 生产力工具栈环境变量配置
#
# Copy to .env and fill ALL values before running:
#   cp .env.example .env && nano .env
#
# Prerequisites:
#   - Run stacks/databases first (PostgreSQL, Redis, MariaDB)
#   - Run stacks/storage first (MinIO)
#   - Run stacks/sso first (Authentik)
#   - Run stacks/base first (Traefik)
# =============================================================================

# --------------------------------------------------------------------------
# DOMAIN & GENERAL
# --------------------------------------------------------------------------
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# --------------------------------------------------------------------------
# DATABASE CREDENTIALS (must match stacks/databases/.env)
# --------------------------------------------------------------------------
POSTGRES_USER=homelab
POSTGRES_ROOT_PASSWORD=changemepostgrespassword

# --------------------------------------------------------------------------
# REDIS PASSWORD (must match stacks/databases/.env)
# --------------------------------------------------------------------------
REDIS_PASSWORD=changeredispassword

# --------------------------------------------------------------------------
# GITEA — Git代码托管
# --------------------------------------------------------------------------
# 数据库密码 (需在databases栈初始化后创建同名数据库)
GITEA_DB_PASSWORD=changegiteapassword

# Gitea OAuth2 JWT Secret — 生成: openssl rand -base64 32
GITEA_OAUTH2_JWT_SECRET=

# --------------------------------------------------------------------------
# VAULTWARDEN — 密码管理器
# --------------------------------------------------------------------------
# Vaultwarden数据库密码
VAULTWARDEN_DB_PASSWORD=changevaultpassword

# Vaultwarden管理令牌 — 生成: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=

# --------------------------------------------------------------------------
# OUTLINE — 团队知识库
# --------------------------------------------------------------------------
# Outline数据库密码
OUTLINE_DB_PASSWORD=changeoutlinepassword

# Outline密钥 — 生成: openssl rand -hex 32
OUTLINE_SECRET_KEY=

# Outline工具密钥 — 生成: openssl rand -hex 32
OUTLINE_UTILS_SECRET=

# --------------------------------------------------------------------------
# STIRLING PDF — PDF处理工具
# --------------------------------------------------------------------------
# Stirling PDF管理员密码 — 生成: openssl rand -hex 16
STIRLING_PDF_ADMIN_PASSWORD=changestirlingpassword

# --------------------------------------------------------------------------
# EXCALIDRAW — 在线白板
# --------------------------------------------------------------------------
# Excalidraw加密密钥 — 生成: openssl rand -hex 32
EXCALIDRAW_ENCRYPTION_KEY=

# --------------------------------------------------------------------------
# SMTP — 邮件通知 (所有服务共用)
# --------------------------------------------------------------------------
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=yourmailpassword
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=HomeLab Stack
SMTP_ENABLED=true

# --------------------------------------------------------------------------
# MINIO (Storage栈提供，Outline文件存储使用)
# --------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeminipassword

# --------------------------------------------------------------------------
# AUTHENTIK OAUTH2 CLIENT CREDENTIALS
# 需在Authentik中创建Application后填充，由scripts/setup-authentik.sh自动填充
# --------------------------------------------------------------------------
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=
