# Database Configuration
POSTGRES_USER=homelab_prod
POSTGRES_PASSWORD=secure_prod_password_2024
POSTGRES_DB=productivity
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secure_redis_password_2024

# Domain Configuration
DOMAIN=homelab.local
GITEA_DOMAIN=git.homelab.local
VAULTWARDEN_DOMAIN=vault.homelab.local
OUTLINE_DOMAIN=docs.homelab.local
STIRLING_DOMAIN=pdf.homelab.local
EXCALIDRAW_DOMAIN=draw.homelab.local

# SSL Configuration
SSL_EMAIL=admin@homelab.local

# Gitea Configuration
GITEA_DB_NAME=gitea
GITEA_SECRET_KEY=gitea_secret_key_change_this_in_production
GITEA_INTERNAL_TOKEN=gitea_internal_token_change_this_in_production
GITEA_JWT_SECRET=gitea_jwt_secret_change_this_in_production

# Gitea OIDC (requires SSO stack)
GITEA_OIDC_CLIENT_ID=gitea
GITEA_OIDC_CLIENT_SECRET=gitea_oidc_secret
GITEA_OIDC_PROVIDER_URL=https://auth.homelab.local/realms/homelab
GITEA_OIDC_SCOPES=openid email profile

# Vaultwarden Configuration
VAULTWARDEN_DB_NAME=vaultwarden
VAULTWARDEN_ADMIN_TOKEN=vaultwarden_admin_token_change_this
VAULTWARDEN_SENDS_ALLOWED=true
VAULTWARDEN_EMERGENCY_ACCESS_ALLOWED=true
VAULTWARDEN_WEB_VAULT_ENABLED=true

# Vaultwarden OIDC (optional)
VAULTWARDEN_OIDC_CLIENT_ID=vaultwarden
VAULTWARDEN_OIDC_CLIENT_SECRET=vaultwarden_oidc_secret
VAULTWARDEN_OIDC_ISSUER=https://auth.homelab.local/realms/homelab

# Outline Configuration
OUTLINE_DB_NAME=outline
OUTLINE_SECRET_KEY=outline_secret_key_change_this_64_chars_long_string
OUTLINE_UTILS_SECRET=outline_utils_secret_change_this_32_chars_long

# Outline OIDC
OUTLINE_OIDC_CLIENT_ID=outline
OUTLINE_OIDC_CLIENT_SECRET=outline_oidc_secret
OUTLINE_OIDC_AUTH_URI=https://auth.homelab.local/realms/homelab/protocol/openid-connect/auth
OUTLINE_OIDC_TOKEN_URI=https://auth.homelab.local/realms/homelab/protocol/openid-connect/token
OUTLINE_OIDC_USERINFO_URI=https://auth.homelab.local/realms/homelab/protocol/openid-connect/userinfo
OUTLINE_OIDC_DISPLAY_NAME=HomeLab SSO

# File Storage
OUTLINE_FILE_STORAGE=local
OUTLINE_FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data

# Stirling PDF Configuration
STIRLING_INSTALL_BOOK_AND_ADVANCED_HTML_OPS=false
STIRLING_LANGS=en_US

# Security Settings
STIRLING_SECURITY_ENABLE_LOGIN=false
STIRLING_SECURITY_CSRF_DISABLED=true

# User and Group IDs
PUID=1000
PGID=1000

# Timezone
TZ=UTC

# Network Configuration
NETWORK_NAME=productivity_network
