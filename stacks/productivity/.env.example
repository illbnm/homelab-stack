# =============================================================================
# Productivity Stack Configuration
# =============================================================================

# Domain
DOMAIN=example.com

# User/Group IDs
PUID=1000
PGID=1000

# PostgreSQL (shared from Databases Stack)
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=your_gitea_db_password
GITEA_SECRET_KEY=your_gitea_secret_key

OUTLINE_DB_USER=outline
OUTLINE_DB_PASSWORD=your_outline_db_password
OUTLINE_SECRET_KEY=your_outline_secret_key_min_32_chars
OUTLINE_UTILS_SECRET=your_outline_utils_secret_min_32_chars

# Redis (shared from Databases Stack)
REDIS_PASSWORD=your_redis_password

# Vaultwarden
VAULTWARDEN_ADMIN_TOKEN=your_admin_token

# Outline OIDC (Authentik)
OUTLINE_OIDC_CLIENT_ID=
OUTLINE_OIDC_CLIENT_SECRET=

# MinIO (for Outline storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Stirling PDF
PDF_CSRF_DISABLED=true
