# =============================================================================
# HomeLab Stack — Productivity Environment Variables
# Copy to .env and fill in values: cp .env.example .env && nano .env
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────
DOMAIN=example.com
TZ=UTC

# ── SMTP (shared by Gitea, Vaultwarden, Outline, BookStack) ─────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=changeme_smtp_password
SMTP_FROM=noreply@example.com

# ── Shared database credentials ─────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ── Gitea ────────────────────────────────────────────────────────────────
GITEA_DB_PASSWORD=changeme_gitea_db
GITEA_SECRET_KEY=changeme_gitea_secret
GITEA_OAUTH2_JWT_SECRET=changeme_gitea_oauth2_jwt
# Generate: docker exec gitea gitea actions generate-runner-token
GITEA_RUNNER_TOKEN=changeme_runner_token

# ── Vaultwarden ──────────────────────────────────────────────────────────
VAULTWARDEN_DB_PASSWORD=changeme_vaultwarden_db
# Generate: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=changeme_vaultwarden_admin_token

# ── Outline + MinIO ─────────────────────────────────────────────────────
OUTLINE_DB_PASSWORD=changeme_outline_db
# Generate: openssl rand -hex 32
OUTLINE_SECRET_KEY=changeme_outline_secret
OUTLINE_UTILS_SECRET=changeme_outline_utils
# Set after creating OIDC app in Authentik
OUTLINE_OAUTH_CLIENT_ID=changeme_outline_oidc_id
OUTLINE_OAUTH_CLIENT_SECRET=changeme_outline_oidc_secret
# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_root_password

# ── BookStack ────────────────────────────────────────────────────────────
BOOKSTACK_DB_PASSWORD=changeme_bookstack_db
# Generate: php -r "echo 'base64:' . base64_encode(random_bytes(32));"
BOOKSTACK_APP_KEY=base64:changeme_bookstack_app_key
BOOKSTACK_AUTH_METHOD=oidc
# Set after creating OIDC app in Authentik
BOOKSTACK_OIDC_CLIENT_ID=changeme_bookstack_oidc_id
BOOKSTACK_OIDC_CLIENT_SECRET=changeme_bookstack_oidc_secret

# ── Authentik (from stacks/sso/.env) ────────────────────────────────────
AUTHENTIK_DOMAIN=auth.example.com
