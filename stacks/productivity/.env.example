# =============================================================================
# Productivity Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values
# cp .env.example .env

# -----------------------------------------------------------------------------
# 系统配置
# -----------------------------------------------------------------------------
# 时区
TZ=Asia/Shanghai

# 域名配置
DOMAIN=yourdomain.com

# Authentik 域名
AUTHENTIK_DOMAIN=authentik.yourdomain.com

# -----------------------------------------------------------------------------
# Gitea 配置
# -----------------------------------------------------------------------------
# Gitea 数据库密码
GITEA_DB_PASSWORD=your_secure_gitea_db_password

# Gitea OAuth2 JWT 密钥 (生成随机字符串)
GITEA_OAUTH2_JWT_SECRET=your_secure_jwt_secret_here

# Gitea SSH 端口
GITEA_SSH_PORT=2222

# Gitea Actions Runner 注册令牌 (在 Gitea 管理后台生成)
GITEA_RUNNER_REGISTRATION_TOKEN=your_runner_token_here

# -----------------------------------------------------------------------------
# Vaultwarden 配置
# -----------------------------------------------------------------------------
# Vaultwarden 数据库密码
VAULTWARDEN_DB_PASSWORD=your_secure_vaultwarden_db_password

# Vaultwarden 管理员令牌 (生成随机字符串，用于访问 /admin)
VAULTWARDEN_ADMIN_TOKEN=your_secure_admin_token_here

# -----------------------------------------------------------------------------
# Outline 配置
# -----------------------------------------------------------------------------
# Outline 数据库密码
OUTLINE_DB_PASSWORD=your_secure_outline_db_password

# Outline 密钥 (生成 32 字节随机字符串)
OUTLINE_SECRET_KEY=your_32_char_secret_key_here

# Outline 工具密钥 (生成 32 字节随机字符串)
OUTLINE_UTILS_SECRET=your_32_char_utils_secret_here

# Outline OAuth 配置 (Authentik)
OUTLINE_OAUTH_CLIENT_ID=your_outline_client_id
OUTLINE_OAUTH_CLIENT_SECRET=your_outline_client_secret

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
# Redis 密码
REDIS_PASSWORD=your_secure_redis_password

# -----------------------------------------------------------------------------
# MinIO 对象存储配置 (Outline 文件存储)
# -----------------------------------------------------------------------------
# MinIO 根用户
MINIO_ROOT_USER=minioadmin

# MinIO 根密码
MINIO_ROOT_PASSWORD=your_secure_minio_password_here

# -----------------------------------------------------------------------------
# SMTP 邮件配置 (Vaultwarden 邀请通知)
# -----------------------------------------------------------------------------
# SMTP 服务器地址
SMTP_HOST=smtp.yourdomain.com

# SMTP 端口 (587=STARTTLS, 465=SSL)
SMTP_PORT=587

# SMTP 发件人邮箱
SMTP_FROM=noreply@yourdomain.com

# SMTP 用户名
SMTP_USER=your_smtp_username

# SMTP 密码
SMTP_PASS=your_smtp_password

# SMTP 安全设置 (starttls, tls, 或 none)
SMTP_SECURITY=starttls

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------
# 支持的语言 (Stirling PDF)
LANGS=en_US,zh_CN
