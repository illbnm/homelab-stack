# Productivity Stack ¡ª Environment Variables
# Copy to .env and fill ALL values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Database passwords (must match databases stack .env)
GITEA_DB_PASSWORD=
VAULTWARDEN_DB_PASSWORD=
OUTLINE_DB_PASSWORD=
BOOKSTACK_DB_PASSWORD=

# Redis password (must match databases stack .env)
REDIS_PASSWORD=

# Secrets ¡ª generate with: openssl rand -hex 32
VAULTWARDEN_ADMIN_TOKEN=
OUTLINE_SECRET_KEY=
OUTLINE_UTILS_SECRET=
GITEA_OAUTH2_JWT_SECRET=

# BookStack ¡ª generate APP_KEY with: echo "base64:$(openssl rand -base64 32)"
BOOKSTACK_APP_KEY=
# Set to 'oidc' to enable SSO (requires OIDC vars below)
BOOKSTACK_AUTH_METHOD=standard

# OAuth2 client credentials ¡ª filled by scripts/setup-authentik.sh
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=
BOOKSTACK_OIDC_CLIENT_ID=
BOOKSTACK_OIDC_CLIENT_SECRET=

# Gitea OIDC (configure in Gitea UI -> Admin -> Authentication)
GITEA_OIDC_NAME=Authentik
GITEA_OIDC_DISCOVERY_URL=https://auth.yourdomain.com/application/o/gitea/.well-known/openid-configuration

# Outline OIDC (already wired in docker-compose.yml)
OUTLINE_OIDC_ISSUER_URL=https://auth.yourdomain.com/application/o/outline/
OUTLINE_OIDC_AUTH_URL=https://auth.yourdomain.com/application/o/authorize/
OUTLINE_OIDC_TOKEN_URL=https://auth.yourdomain.com/application/o/token/
OUTLINE_OIDC_USERINFO_URL=https://auth.yourdomain.com/application/o/userinfo/
OUTLINE_OIDC_LOGOUT_URL=https://auth.yourdomain.com/application/o/outline/end-session/
