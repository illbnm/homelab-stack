# Productivity Stack Environment Variables

# Domain
DOMAIN=homelab.local

# =============================================================================
# Gitea
# =============================================================================
GITEA_DB_PASSWORD=gitea_secret
GITEA_OAUTH2_JWT_SECRET=$(openssl rand -base64 32)

# =============================================================================
# Vaultwarden
# =============================================================================
VAULTWARDEN_ADMIN_TOKEN=$(openssl rand -base64 32)
VAULTWARDEN_DB_PASSWORD=vaultwarden_secret

# =============================================================================
# Outline
# =============================================================================
OUTLINE_SECRET_KEY=$(openssl rand -base64 32)
OUTLINE_UTILS_SECRET=$(openssl rand -base64 32)
OUTLINE_DB_PASSWORD=outline_secret
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=

# =============================================================================
# Stirling PDF
# =============================================================================
# No additional configuration required

# =============================================================================
# SMTP Configuration (for Vaultwarden, Outline)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=

# Timezone
TZ=Asia/Shanghai
