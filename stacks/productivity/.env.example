# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password
MYSQL_PASSWORD=your_secure_mysql_password
MYSQL_ROOT_PASSWORD=your_secure_mysql_root_password

# Gitea Configuration
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASSWORD=your_secure_gitea_admin_password
GITEA_SECRET_KEY=your_gitea_secret_key
GITEA_JWT_SECRET=your_gitea_jwt_secret

# Vaultwarden Configuration
VAULTWARDEN_ADMIN_TOKEN=your_vaultwarden_admin_token
VAULTWARDEN_DATABASE_URL=postgresql://vaultwarden:your_secure_postgres_password@postgres:5432/vaultwarden

# Outline Configuration
OUTLINE_SECRET_KEY=your_outline_secret_key
OUTLINE_UTILS_SECRET=your_outline_utils_secret
OUTLINE_DATABASE_URL=postgresql://outline:your_secure_postgres_password@postgres:5432/outline
OUTLINE_REDIS_URL=redis://redis:6379
OUTLINE_SMTP_HOST=smtp.example.com
OUTLINE_SMTP_PORT=587
OUTLINE_SMTP_USERNAME=your_smtp_username
OUTLINE_SMTP_PASSWORD=your_smtp_password
OUTLINE_SMTP_FROM_EMAIL=noreply@example.com

# BookStack Configuration
BOOKSTACK_APP_KEY=base64:your_bookstack_app_key
BOOKSTACK_DB_PASSWORD=your_secure_mysql_password
BOOKSTACK_MAIL_HOST=smtp.example.com
BOOKSTACK_MAIL_PORT=587
BOOKSTACK_MAIL_USERNAME=your_smtp_username
BOOKSTACK_MAIL_PASSWORD=your_smtp_password
BOOKSTACK_MAIL_FROM_EMAIL=noreply@example.com

# Domain Configuration
DOMAIN=localhost
GITEA_DOMAIN=gitea.localhost
VAULTWARDEN_DOMAIN=vault.localhost
OUTLINE_DOMAIN=outline.localhost
BOOKSTACK_DOMAIN=books.localhost

# SSL Configuration
ENABLE_SSL=false
CERT_EMAIL=admin@example.com