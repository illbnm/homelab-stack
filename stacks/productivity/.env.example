# =============================================================================
# Productivity Stack — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# GITEA
# -----------------------------------------------------------------------------
GITEA_DB_PASSWORD=             # REQUIRED: must match databases initdb script
GITEA_OAUTH2_JWT_SECRET=       # REQUIRED: openssl rand -hex 32

# -----------------------------------------------------------------------------
# VAULTWARDEN
# -----------------------------------------------------------------------------
VAULTWARDEN_ADMIN_TOKEN=       # REQUIRED: openssl rand -base64 48
VAULTWARDEN_DB_PASSWORD=       # REQUIRED: must match databases initdb script

# Vaultwarden SMTP (email notifications)
SMTP_HOST=                     # REQUIRED: SMTP server hostname
SMTP_PORT=587                  # SMTP port (587 for STARTTLS)
SMTP_USER=                     # SMTP username
SMTP_PASS=                     # SMTP password
SMTP_FROM=                     # From address for emails (default: vaultwarden@DOMAIN)

# -----------------------------------------------------------------------------
# OUTLINE (Wiki)
# -----------------------------------------------------------------------------
OUTLINE_SECRET_KEY=            # REQUIRED: openssl rand -hex 32
OUTLINE_UTILS_SECRET=          # REQUIRED: openssl rand -hex 32
OUTLINE_DB_PASSWORD=           # REQUIRED: must match databases initdb script
OUTLINE_OAUTH_CLIENT_ID=       # Set by scripts/setup-authentik.sh
OUTLINE_OAUTH_CLIENT_SECRET=   # Set by scripts/setup-authentik.sh

# -----------------------------------------------------------------------------
# BOOKSTACK
# -----------------------------------------------------------------------------
BOOKSTACK_APP_KEY=             # REQUIRED: php -r "echo 'base64:'.base64_encode(random_bytes(32));"
BOOKSTACK_DB_PASSWORD=         # REQUIRED: must match databases initdb script
BOOKSTACK_AUTH_METHOD=standard # standard | oidc | saml2
BOOKSTACK_OIDC_CLIENT_ID=      # Set if AUTH_METHOD=oidc
BOOKSTACK_OIDC_CLIENT_SECRET=  # Set if AUTH_METHOD=oidc

# -----------------------------------------------------------------------------
# COMMON (from root .env)
# -----------------------------------------------------------------------------
# DOMAIN, TZ, REDIS_PASSWORD, AUTHENTIK_DOMAIN — inherited from root .env
