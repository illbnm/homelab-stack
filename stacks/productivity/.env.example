# Productivity Stack — Environment Variables
# Copy to .env and fill ALL values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# =============================================================================
# Database Passwords (must match databases stack .env)
# =============================================================================
GITEA_DB_PASSWORD=
VAULTWARDEN_DB_PASSWORD=
OUTLINE_DB_PASSWORD=
BOOKSTACK_DB_PASSWORD=

# Redis password (must match databases stack .env)
REDIS_PASSWORD=

# =============================================================================
# Secrets — generate with: openssl rand -hex 32
# =============================================================================
VAULTWARDEN_ADMIN_TOKEN=
OUTLINE_SECRET_KEY=
OUTLINE_UTILS_SECRET=
GITEA_OAUTH2_JWT_SECRET=

# BookStack — generate APP_KEY with: echo "base64:$(openssl rand -base64 32)"
BOOKSTACK_APP_KEY=
# Set to 'oidc' to enable SSO (requires OIDC vars below)
BOOKSTACK_AUTH_METHOD=standard

# =============================================================================
# OAuth2 Client Credentials (filled by scripts/setup-authentik.sh)
# =============================================================================

# Gitea OIDC
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=

# Outline OIDC
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=

# BookStack OIDC (optional)
BOOKSTACK_OIDC_CLIENT_ID=
BOOKSTACK_OIDC_CLIENT_SECRET=

# =============================================================================
# Gitea OIDC Configuration
# =============================================================================
GITEA__OAUTH2__ENABLED=true
GITEA__OAUTH2__NAME=Authentik
GITEA__OAUTH2__CLIENT_ID=${GITEA_OAUTH_CLIENT_ID}
GITEA__OAUTH2__CLIENT_SECRET=${GITEA_OAUTH_CLIENT_SECRET}
GITEA__OAUTH2__PROVIDER_URL=https://${AUTHENTIK_DOMAIN}/application/o/gitea/
GITEA__OAUTH2__SIGN_UP=true
GITEA__OAUTH2__AUTO_DISCOVER_USER_INFO=true

# =============================================================================
# Outline OIDC Configuration
# =============================================================================
OUTLINE_OIDC_CLIENT_ID=${OUTLINE_OAUTH_CLIENT_ID}
OUTLINE_OIDC_CLIENT_SECRET=${OUTLINE_OAUTH_CLIENT_SECRET}
OUTLINE_OIDC_ISSUER=https://${AUTHENTIK_DOMAIN}/application/o/outline/
OUTLINE_OIDC_SCOPES=openid profile email
OUTLINE_OIDC_USERNAME_CLAIM=preferred_username
OUTLINE_OIDC_EMAIL_CLAIM=email
OUTLINE_OIDC_DISPLAY_NAME_CLAIM=name

# =============================================================================
# BookStack OIDC Configuration (optional)
# =============================================================================
# BOOKSTACK_AUTH_METHOD=oidc
# BOOKSTACK_OIDC_CLIENT_ID=${BOOKSTACK_OIDC_CLIENT_ID}
# BOOKSTACK_OIDC_CLIENT_SECRET=${BOOKSTACK_OIDC_CLIENT_SECRET}
# BOOKSTACK_OIDC_ISSUER=https://${AUTHENTIK_DOMAIN}/application/o/bookstack/
# BOOKSTACK_OIDC_DISPLAY_NAME_CLAIM=name
# BOOKSTACK_OIDC_EMAIL_CLAIM=email
