# Productivity Stack — Environment Variables
# Copy to .env and fill in your values

# General
TZ=Europe/Berlin
DOMAIN=yourdomain.com

# Gitea
GITEA_DISABLE_REGISTRATION=true
GITEA_REQUIRE_SIGNIN=true

# Vaultwarden
# Generate admin token: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=change_me_generate_a_strong_token
VAULTWARDEN_SIGNUPS=false
VAULTWARDEN_INVITATIONS=true
