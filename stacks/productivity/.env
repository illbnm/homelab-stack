# Gitea OIDC Configuration
GITEA_OIDC_CLIENT_ID=your-client-id
GITEA_OIDC_CLIENT_SECRET=your-client-secret
GITEA_OIDC_REDIRECT_URI=https://gitea.example.com/user/oauth2/callback

# Outline OIDC Configuration
OUTLINE_OIDC_CLIENT_ID=your-client-id
OUTLINE_OIDC_CLIENT_SECRET=your-client-secret
OUTLINE_OIDC_REDIRECT_URI=https://outline.example.com/auth/oidc/callback