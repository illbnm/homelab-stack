# Notifications Stack Environment Configuration

# Domain Configuration
NOTIFICATIONS_DOMAIN=notifications.homelab.local
GOTIFY_DOMAIN=gotify.homelab.local

# Gotify Configuration
GOTIFY_ADMIN_USER=admin
GOTIFY_ADMIN_PASS=your-secure-admin-password
GOTIFY_DEFAULT_USER=homelab
GOTIFY_DEFAULT_PASS=your-default-user-password

# Database Settings
POSTGRES_DB=gotify
POSTGRES_USER=gotify
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=gotify-db
POSTGRES_PORT=5432

# Redis Configuration (for caching)
REDIS_PASSWORD=your-redis-password

# Apprise Configuration
APPRISE_API_KEY=your-apprise-api-key
APPRISE_CONFIG_DIR=./config/apprise

# Network Settings
NOTIFICATIONS_NETWORK=notifications-net
TRAEFIK_NETWORK=traefik-public

# Volumes
GOTIFY_DATA_PATH=./data/gotify
APPRISE_CONFIG_PATH=./config/apprise
POSTGRES_DATA_PATH=./data/postgres
REDIS_DATA_PATH=./data/redis

# Security Settings
JWT_SECRET=your-jwt-secret-key-32-chars-long
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data

# Email SMTP (for email notifications via Apprise)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=homelab@yourdomain.com

# Webhook URLs (examples for Apprise)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Monitoring Integration
PROMETHEUS_ENABLED=true
METRICS_PORT=8080

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
