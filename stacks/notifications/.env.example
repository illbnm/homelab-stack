# =============================================================================
# Notifications Stack — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------
# GOTIFY
# ---------------------------------------------------------------------
# REQUIRED: Strong password for the gotify admin user (min 8 chars)
# Generate secure password: openssl rand -base64 24
GOTIFY_PASSWORD=

# Optional: Static admin token for API access (auto-generated if blank)
# Generate token: openssl rand -base64 32
GOTIFY_ADMIN_TOKEN=

# ---------------------------------------------------------------------
# NTFY
# ---------------------------------------------------------------------
# Bearer token for Ntfy authentication (optional — leave blank to disable auth)
# Generate token: openssl rand -base64 32
# When set, anonymous access is disabled and clients must use this token
NTFY_AUTH_TOKEN=

# ---------------------------------------------------------------------
# Traefik Domain (REQUIRED for all services)
# ---------------------------------------------------------------------
# DOMAIN=your-domain.example.com
