# ===================
# 基础配置
# ===================

# 你的域名
DOMAIN=example.com

# 时区
TZ=Asia/Shanghai

# ===================
# ntfy
# ===================

# ntfy 管理员用户名
NTFY_ADMIN_USER=admin

# ntfy 管理员密码
NTFY_ADMIN_PASSWORD=your-secure-password

# ===================
# Gotify
# ===================

# Gotify 管理员用户名
GOTIFY_ADMIN_USER=admin

# Gotify 管理员密码
GOTIFY_ADMIN_PASSWORD=your-gotify-password

# Gotify API Token (应用令牌)
GOTIFY_APP_TOKEN=your-app-token
