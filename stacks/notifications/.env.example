# Notifications Stack Environment Variables
# Copy this file to .env and fill in your values

# Domain Configuration
DOMAIN=your-domain.com

# Timezone
TZ=Asia/Shanghai

# Gotify Admin Credentials
# Change these to secure values!
GOTIFY_ADMIN_USER=admin
GOTIFY_ADMIN_PASS=your_secure_password_here

# Gotify App Token (for API calls)
# Generate this in Gotify Web UI after first login
GOTIFY_TOKEN=your_app_token_here

# Optional: ntfy Firebase Configuration (for mobile push)
# Get this from Firebase Console
# FIREBASE_KEY_FILE=/etc/ntfy/firebase-key.json

# Optional: ntfy SMTP Configuration (for email notifications)
# SMTP_USER=ntfy@your-domain.com
# SMTP_PASS=your_smtp_password
# SMTP_SERVER=smtp.your-domain.com:587
