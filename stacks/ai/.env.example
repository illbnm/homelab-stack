# AI Stack - Environment Variables
# Copy to .env and fill ALL values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Open WebUI secrets
WEBUI_SECRET_KEY=

# Open WebUI OIDC (Authentik)
OPENWEBUI_OIDC_CLIENT_ID=
OPENWEBUI_OIDC_CLIENT_SECRET=
OPENWEBUI_OIDC_AUTH_URL=https://auth.yourdomain.com/application/o/authorize/
OPENWEBUI_OIDC_TOKEN_URL=https://auth.yourdomain.com/application/o/token/
OPENWEBUI_OIDC_USERINFO_URL=https://auth.yourdomain.com/application/o/userinfo/
OPENWEBUI_OIDC_SCOPES=openid profile email
OPENWEBUI_OIDC_REDIRECT_URL=https://ai.yourdomain.com/oauth/callback
