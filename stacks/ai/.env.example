# Required environment variables — copy to .env and fill in values

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Open WebUI secret (generate a random 32+ char string)
WEBUI_SECRET_KEY=changeme-generate-a-random-secret-here

# Authentik OIDC — run scripts/setup-authentik.sh first to get these
OPENWEBUI_OIDC_CLIENT_ID=
OPENWEBUI_OIDC_CLIENT_SECRET=
AUTHENTIK_DOMAIN=auth.yourdomain.com
