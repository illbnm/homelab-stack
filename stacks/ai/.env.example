# =============================================================================
# AI Stack — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Your domain (used for Traefik routing: ai.${DOMAIN}, sd.${DOMAIN}, search.${DOMAIN})
DOMAIN=example.com

# Timezone
TZ=Asia/Shanghai

# ---------------------------------------------------------------------------
# GPU Configuration
# ---------------------------------------------------------------------------
# GPU mode: nvidia | amd | cpu (default: cpu)
# - nvidia: NVIDIA GPU with CUDA support
# - amd:    AMD GPU with ROCm support
# - cpu:   CPU-only mode (default)
ENABLE_GPU=cpu

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------
# Ollama API port (internal exposure)
OLLAMA_PORT=11434

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
# Secret key for Open WebUI session management (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=change_me_to_random_string

# Default locale for Open WebUI (e.g. zh-CN, en-US)
DEFAULT_LOCALE=zh-CN

# ---------------------------------------------------------------------------
# Open WebUI OIDC/Authentik Authentication (Optional)
# Run scripts/setup-authentik.sh first to create the OAuth provider
# ---------------------------------------------------------------------------
# OIDC Client ID (from setup-authentik.sh)
OPEN_WEBUI_OAUTH_CLIENT_ID=

# OIDC Client Secret (from setup-authentik.sh)
OPEN_WEBUI_OAUTH_CLIENT_SECRET=

# OIDC Issuer URL (Authentik application URL)
OPEN_WEBUI_OAUTH_ISSUER=https://auth.example.com/application/o/openwebui/

# OIDC Callback URL (must match Authentik provider redirect URI)
OPEN_WEBUI_OAUTH_CALLBACK_URL=https://ai.example.com/auth/callback

# OIDC Scopes (default includes openid, profile, email)
OPEN_WEBUI_OAUTH_SCOPES=openid profile email

# Claims configuration
OPEN_WEBUI_OIDC_EMAIL_CLAIM=email
OPEN_WEBUI_OIDC_NAME_CLAIM=name
OPEN_WEBUI_OIDC_USERNAME_CLAIM=preferred_username

# Auto-provision new users (creates account on first OIDC login)
OPEN_WEBUI_AUTO_PROVISION=false

# ---------------------------------------------------------------------------
# Stable Diffusion (optional, enable with: docker compose --profile sd up -d)
# ---------------------------------------------------------------------------
# Command-line arguments for Stable Diffusion WebUI
# NVIDIA GPU:
#   SD_ARGS=--xformers --enable-insecure-extension-access --api
# AMD GPU:
#   SD_ARGS=--opt-split-attention --precision full --no-half
# CPU only (default):
SD_ARGS=--no-half --skip-torch-cuda-test --use-cpu all

# ---------------------------------------------------------------------------
# Perplexica (AI Search)
# ---------------------------------------------------------------------------
# Ollama model to use for search
SEARCH_MODELS=llama3:8b

# Similarity model for embeddings
SIMILARITY_MODEL=bge-m3
