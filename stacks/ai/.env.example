# AI Stack — Environment Configuration
# Copy to .env and customize before launching.

# Domain (inherited from root .env or set here)
DOMAIN=localhost

# GPU Runtime: nvidia | rocm | cpu
# - nvidia: Requires NVIDIA Container Toolkit (nvidia-docker2)
# - rocm:   Requires AMD ROCm drivers
# - cpu:    No GPU acceleration (default)
GPU_RUNTIME=cpu

# Stable Diffusion CLI args
# For NVIDIA GPU: remove --no-half --skip-torch-cuda-test --use-cpu all
# For CPU only:   --no-half --skip-torch-cuda-test --use-cpu all
SD_CLI_ARGS=--no-half --skip-torch-cuda-test --use-cpu all

# Ollama tuning
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# Open WebUI
WEBUI_SECRET_KEY=CHANGE_ME_32_CHAR_SECRET_KEY_HERE
ENABLE_SIGNUP=false

# Authentik OIDC for Open WebUI (optional)
AUTHENTIK_DOMAIN=auth.yourdomain.com
AI_OAUTH_CLIENT_ID=
AI_OAUTH_CLIENT_SECRET=

# Perplexica
SEARXNG_URL=
