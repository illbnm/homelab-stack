# =============================================================================
# AI Stack — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# GPU RUNTIME SELECTION
# Options: nvidia | amd | cpu (default)
# - nvidia: Requires NVIDIA GPU + nvidia-container-toolkit
# - amd: Requires AMD GPU with ROCm support
# - cpu: Pure CPU inference (no GPU required)
# -----------------------------------------------------------------------------
GPU_RUNTIME=cpu

# -----------------------------------------------------------------------------
# OPEN WEBUI
# Generate secret: openssl rand -hex 32
# -----------------------------------------------------------------------------
WEBUI_SECRET_KEY=CHANGE_ME_RANDOM_32_CHAR_SECRET
DEFAULT_LOCALE=zh-CN

# -----------------------------------------------------------------------------
# SEARXNG (Perplexica dependency)
# Generate secret: openssl rand -hex 32
# -----------------------------------------------------------------------------
SEARXNG_SECRET=CHANGE_ME_RANDOM_32_CHAR_SECRET

# -----------------------------------------------------------------------------
# OLLAMA GPU SETTINGS (Optional)
# For NVIDIA GPU, set GPU_RUNTIME=nvidia and ensure nvidia-container-toolkit
# is installed. For AMD GPU, set GPU_RUNTIME=amd.
# -----------------------------------------------------------------------------
# OLLAMA_GPU_ENABLED=false  # Legacy, use GPU_RUNTIME instead