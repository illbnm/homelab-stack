# AI Stack 环境变量配置

# 域名配置（用于 Traefik 反向代理）
DOMAIN=your-domain.com

# Open WebUI 密钥（必须是 32 字符以上的随机字符串）
# 生成方法：openssl rand -hex 32
WEBUI_SECRET_KEY=your-secret-key-here-32-chars-minimum-required

# Ollama 配置（可选）
# 预拉取的模型列表，空格分隔
OLLAMA_MODELS=llama3.2:3b qwen2.5:7b

# Ollama 并发配置（可选）
# OLLAMA_MAX_QUEUE=512
# OLLAMA_NUM_PARALLEL=4

# Stable Diffusion 配置（可选）
# COMMANDLINE_ARGS=--opt-split-attention --xformers

# GPU 类型（nvidia/amd/cpu）
GPU_TYPE=cpu
