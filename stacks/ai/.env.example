# ─────────────────────────────────────────────────────────────
# AI Stack Configuration
# ─────────────────────────────────────────────────────────────

# Domain Configuration
DOMAIN=example.com

# Open WebUI Configuration
WEBUI_SECRET_KEY=changeme-open-webui-secret-key-min-32-chars
ENABLE_SIGNUP=false

# Perplexica Configuration
PERPLEXICA_SECRET_KEY=changeme-perplexica-secret-key-min-32-chars

# GPU Configuration (optional)
# Uncomment ONE of the following based on your hardware:

# NVIDIA GPU: Set to "nvidia"
# GPU_DRIVER=nvidia

# AMD GPU (ROCm): Set to "amd"  
# GPU_DRIVER=amd

# CPU Only (default): Leave commented or set to "cpu"
# GPU_DRIVER=cpu

# Ollama Model Configuration
# Pre-pull models on first start (comma-separated)
OLLAMA_MODELS=llama3.2:3b,qwen2.5:7b

# Stable Diffusion Configuration
# Default model to download (optional)
SD_MODEL=runwayml/stable-diffusion-v1-5

# Resource Limits (optional)
# OLLAMA_MEMORY_LIMIT=8g
# SD_MEMORY_LIMIT=16g
