# ============================================================
# AI Stack — Environment Variables
# ============================================================

# ─── Global ──────────────────────────────────────────────────
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# ─── GPU Runtime ─────────────────────────────────────────────
# Run: bash scripts/detect-gpu.sh to auto-detect
# Options: nvidia | (empty for CPU)
GPU_RUNTIME=
# Stable Diffusion CLI args (auto-set by detect-gpu.sh)
SD_ARGS=--no-half --skip-torch-cuda-test --use-cpu all --precision full

# ─── Ollama ──────────────────────────────────────────────────
OLLAMA_DEFAULT_MODEL=qwen2.5:7b     # Auto-pulled on first start
OLLAMA_NUM_PARALLEL=2               # Concurrent inference requests
OLLAMA_MAX_MODELS=2                 # Max models loaded in memory

# ─── Open WebUI ──────────────────────────────────────────────
WEBUI_SECRET_KEY=                   # openssl rand -hex 32
WEBUI_AUTH=true                     # Require login
ENABLE_SIGNUP=false                 # Disable public registration
DEFAULT_LOCALE=zh-CN                # UI language
