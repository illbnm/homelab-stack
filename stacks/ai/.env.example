# =============================================================================
# AI Stack — Environment Variables
# Copy this file to .env inside this directory:
#   cp .env.example .env
# Then fill in your values.
# =============================================================================

# Domain (must match your base stack .env)
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# ---------------------------------------------------------------------------
# Open WebUI — Secret Key
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=

# ---------------------------------------------------------------------------
# Ollama — Local LLM Inference
# ---------------------------------------------------------------------------
# Ollama version (check https://hub.docker.com/r/ollama/ollama/tags)
OLLAMA_VERSION=0.5.16

# GPU count: "all" uses all GPUs, or specific number like "1", "2"
# Leave empty/0 to disable GPU (runs on CPU only)
OLLAMA_GPU_COUNT=all

# Models to preload on startup (space-separated).
# Examples:
#   OLLAMA_PRELOAD_MODELS=llama3:8b
#   OLLAMA_PRELOAD_MODELS=llama3:8b mistral:7b qwen2.5:7b
#   OLLAMA_PRELOAD_MODELS=nomic-embed-text
# Find all available: https://ollama.com/library
# To pull models manually after start: docker exec ollama ollama pull <model>
OLLAMA_PRELOAD_MODELS=

# ---------------------------------------------------------------------------
# Open WebUI — Web Interface for Ollama
# ---------------------------------------------------------------------------
# Open WebUI version
OPEN_WEBUI_VERSION=0.6.5

# Default UI language
DEFAULT_LOCALE=zh-CN

# ---------------------------------------------------------------------------
# A1111 Stable Diffusion WebUI — Image Generation
# ---------------------------------------------------------------------------
# Stable Diffusion version
SD_VERSION=1.10.3

# GPU count for SD WebUI: "all" or specific number
SD_GPU_COUNT=all

# Extra CLI arguments passed to SD WebUI
# Defaults: --api --listen --opt-sdp-attention
# Add --xformers for faster generation (if supported by your GPU)
# Add --medvram to save VRAM on low-end GPUs
# Add --precision full --no-half to force full precision (slower, more VRAM)
SD_CLI_ARGS=--api --listen --opt-sdp-attention

# Torch dtype: float16 (default, fast), float32 (slower, more VRAM)
SD_TORCH_DTYPE=float16

# Model to auto-download on first start.
# Leave empty to use the default built-in model.
# Find models at: https://huggingface.co/models?other=stable-diffusion
# Examples:
#   SD_MODEL_ID=stabilityai/stable-diffusion-3-medium
#   SD_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
#   SD_MODEL_ID=gsdf/CounterfeitXL
SD_MODEL_ID=
SD_MODEL_REVISION=

# Extra Python args (rarely needed)
# SD_PYTHON_ARGS=
