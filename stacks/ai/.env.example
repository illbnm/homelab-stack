# =============================================================================
# HomeLab Stack — AI Stack Environment Variables
# Copy to .env and fill ALL values before running.
# Run: cp .env.example .env && nano .env
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
DOMAIN=yourdomain.com           # Your base domain (e.g. home.example.com)

# -----------------------------------------------------------------------------
# Authentik SSO (optional — for OIDC login to Open WebUI)
# -----------------------------------------------------------------------------
AUTHENTIK_DOMAIN=auth.${DOMAIN}

# OAuth2 client credentials — filled by scripts/setup-authentik.sh
# Leave empty to disable SSO (local login only)
OPEN_WEBUI_OAUTH_CLIENT_ID=
OPEN_WEBUI_OAUTH_CLIENT_SECRET=

# SSO behavior
# Set to true to enable SSO-only login (disables local login form)
OIDC_DISABLE_LOGIN_FORM=false
# Set to true to allow new user registration via OAuth
OIDC_ENABLE_SIGNUP=false
# Provider name shown on login button
OIDC_PROVIDER_NAME=authentik
# OIDC issuer URL (auto-generated from AUTHENTIK_DOMAIN if using Authentik)
OIDC_ISSUER_URL=https://${AUTHENTIK_DOMAIN}/application/o/open-webui/.well-known/openid-configuration

# -----------------------------------------------------------------------------
# Ollama
# -----------------------------------------------------------------------------
# GPU type: nvidia | amd | cpu
# Set to match your hardware. CPU works on all systems.
OLLAMA_GPU_TYPE=cpu

# Models to auto-download on first start (space-separated list)
# Use 'docker compose --profile download up' to run model downloader
# Examples:
#   - llama3.3
#   - llama3.3 mistral
#   - llama3.3:70b mistral:7b
OLLAMA_MODELS=llama3.3 mistral

# Shared models path (host path — must match AI_MODELS_PATH below)
AI_MODELS_PATH=/opt/homelab/models

# WebUI secret key — generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=

# -----------------------------------------------------------------------------
# Stable Diffusion
# -----------------------------------------------------------------------------
# GPU type: nvidia | amd | cpu (must match OLLAMA_GPU_TYPE if using same GPU)
SD_GPU_TYPE=cpu

# NVIDIA GPU device ID (default: 0)
# For multiple GPUs, use comma-separated: SD_CUDA_VISIBLE_DEVICES=0,1
SD_CUDA_VISIBLE_DEVICES=0

# Command line args for Stable Diffusion WebUI
# Adjust based on your GPU:
#
# NVIDIA GPU (recommended):
#   --xformers --enable-insecure-extension-access --api
#
# AMD GPU (ROCm):
#   --use-rocmm --enable-insecure-extension-access --api
#
# CPU only:
#   --no-half --skip-torch-cuda-test --use-cpu all --force-enable-textseg --api
#
SD_COMMANDLINE_ARGS=--no-half --skip-torch-cuda-test --use-cpu all --force-enable-textseg

# -----------------------------------------------------------------------------
# RAG / Vector DB (optional — for Open WebUI RAG feature)
# -----------------------------------------------------------------------------
# Enable RAG feature in Open WebUI
ENABLE_RAG=false
# Vector DB type: chroma | qdrant | milvus
VECTOR_DB=chroma
# Embedding model for RAG (used with nomic-embed-text by default)
RAG_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Locale
# -----------------------------------------------------------------------------
DEFAULT_LOCALE=zh-CN
