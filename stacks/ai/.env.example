# AI Stack — Environment Variables
# Copy to .env and fill ALL values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# OAuth2 client credentials — auto-filled by scripts/setup-authentik.sh
OPENWEBUI_OAUTH_CLIENT_ID=
OPENWEBUI_OAUTH_CLIENT_SECRET=

# Open WebUI secrets
WEBUI_SECRET_KEY=  # Generate: openssl rand -base64 32

# Ollama configuration
OLLAMA_GPU_ENABLED=false  # Set to true if you have NVIDIA GPU
