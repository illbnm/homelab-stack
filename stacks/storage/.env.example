# Storage Stack
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Nextcloud admin
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Database — must match databases stack NEXTCLOUD_DB_PASSWORD
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Nextcloud OIDC (optional — fill after running setup-authentik.sh)
AUTHENTIK_DOMAIN=auth.yourdomain.com
NEXTCLOUD_OIDC_ENABLED=false
NEXTCLOUD_OIDC_CLIENT_ID=
NEXTCLOUD_OIDC_CLIENT_SECRET=
NEXTCLOUD_OIDC_AUTO_REDIRECT=false

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# FileBrowser
STORAGE_PATH=/data
