# Storage Stack — Environment Variables

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# =============================================================================
# Nextcloud Admin
# =============================================================================
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# =============================================================================
# Database (must match databases stack)
# =============================================================================
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# =============================================================================
# MinIO
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# =============================================================================
# FileBrowser
# =============================================================================
FILEBROWSER_ROOT=/data

# =============================================================================
# Nextcloud OIDC (filled by scripts/setup-authentik.sh)
# =============================================================================
NEXTCLOUD_OAUTH_CLIENT_ID=
NEXTCLOUD_OAUTH_CLIENT_SECRET=
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Nextcloud Social Login OIDC Configuration
# These are set via occ command by setup script, but can be set manually:
# NEXTCLOUD_OIDC_PROVIDER=Authentik
# NEXTCLOUD_OIDC_CLIENT_ID=${NEXTCLOUD_OAUTH_CLIENT_ID}
# NEXTCLOUD_OIDC_CLIENT_SECRET=${NEXTCLOUD_OAUTH_CLIENT_SECRET}
# NEXTCLOUD_OIDC_AUTH_URL=https://${AUTHENTIK_DOMAIN}/application/o/authorize/
# NEXTCLOUD_OIDC_TOKEN_URL=https://${AUTHENTIK_DOMAIN}/application/o/token/
# NEXTCLOUD_OIDC_RESOURCE_URL=https://${AUTHENTIK_DOMAIN}/application/o/userinfo/
