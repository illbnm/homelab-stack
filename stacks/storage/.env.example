# =============================================================================
# Storage Stack — Environment Variables
# =============================================================================
TZ=Asia/Shanghai
DOMAIN=yourdomain.com

# Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NEXTCLOUD_DB_PASSWORD

# Database (must match databases stack)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_STRONG_PASSWORD

# FileBrowser & Syncthing
STORAGE_PATH=/data
