# =============================================================================
# Storage Stack - 环境变量配置
# =============================================================================
# 复制此文件为 .env 并根据实际情况修改
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------
# 主域名 (用于 Traefik 反向代理)
DOMAIN=yourdomain.com

# 时区
TZ=Asia/Shanghai

# 用户 ID 和组 ID (用于文件权限)
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# 数据存储路径
# -----------------------------------------------------------------------------
# 共享存储根目录 (Nextcloud/MinIO/FileBrowser/Syncthing 共享)
STORAGE_PATH=/data/storage

# -----------------------------------------------------------------------------
# Nextcloud 配置
# -----------------------------------------------------------------------------
# Nextcloud 访问域名
NEXTCLOUD_DOMAIN=nextcloud.yourdomain.com

# Nextcloud 管理员账号
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Nextcloud 数据库配置 (必须与 databases stack 一致)
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# -----------------------------------------------------------------------------
# MinIO 配置
# -----------------------------------------------------------------------------
# MinIO 访问凭证
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# MinIO 域名
# API: s3.yourdomain.com
# Console: minio.yourdomain.com

# -----------------------------------------------------------------------------
# FileBrowser 配置
# -----------------------------------------------------------------------------
# FileBrowser 访问域名：files.yourdomain.com
# 默认用户名：admin
# 默认密码：admin (首次登录后请立即修改！)

# -----------------------------------------------------------------------------
# Syncthing 配置
# -----------------------------------------------------------------------------
# Syncthing 同步端口 (TCP/UDP)
SYNCTHING_TCP_PORT=22000
SYNCTHING_UDP_PORT=22000
SYNCTHING_DISCOVERY_PORT=21027

# -----------------------------------------------------------------------------
# 共享数据库配置 (必须与 databases stack 一致)
# -----------------------------------------------------------------------------
# PostgreSQL
POSTGRES_USER=homelab
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# -----------------------------------------------------------------------------
# Authentik OIDC 配置 (可选，用于 SSO 登录)
# -----------------------------------------------------------------------------
# 如果需要使用 Authentik 单点登录，取消以下注释并配置
# AUTHENTIK_URL=https://authentik.yourdomain.com
# NEXTCLOUD_OIDC_CLIENT_ID=nextcloud-client-id
# NEXTCLOUD_OIDC_CLIENT_SECRET=nextcloud-client-secret
