# =============================================================================
# HomeLab Storage Stack — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- General ---
TZ=Asia/Shanghai
DOMAIN=example.com

# --- Nextcloud ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme
NEXTCLOUD_DOMAIN=cloud.example.com
NEXTCLOUD_DB_NAME=nextcloud

# --- PostgreSQL (shared with Databases stack) ---
POSTGRES_USER=nc_user
POSTGRES_PASSWORD=changeme

# --- Redis (shared with Databases stack) ---
REDIS_PASSWORD=changeme

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme12345678

# --- FileBrowser ---
FILEBROWSER_ADMIN_PASS=changeme

# --- Storage Paths ---
STORAGE_ROOT=/data/storage

# --- Syncthing ---
PUID=1000
PGID=1000
