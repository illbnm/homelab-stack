# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_EMAIL=admin@example.com

# Domain Configuration
NEXTCLOUD_DOMAIN=nextcloud.yourdomain.com
FILEBROWSER_DOMAIN=filebrowser.yourdomain.com
MINIO_DOMAIN=minio.yourdomain.com
MINIO_CONSOLE_DOMAIN=minio-console.yourdomain.com

# Storage Paths
NEXTCLOUD_DATA_PATH=/opt/storage/nextcloud/data
NEXTCLOUD_CONFIG_PATH=/opt/storage/nextcloud/config
NEXTCLOUD_APPS_PATH=/opt/storage/nextcloud/apps
MINIO_DATA_PATH=/opt/storage/minio/data
MINIO_CONFIG_PATH=/opt/storage/minio/config
FILEBROWSER_DATA_PATH=/opt/storage/filebrowser/data
FILEBROWSER_CONFIG_PATH=/opt/storage/filebrowser/config

# Database Configuration
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=securepassword123
POSTGRES_DATA_PATH=/opt/storage/postgres/data

# Redis Configuration
REDIS_PASSWORD=redispassword123
REDIS_DATA_PATH=/opt/storage/redis/data

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BROWSER_REDIRECT_URL=https://minio-console.yourdomain.com

# Nextcloud Configuration
NEXTCLOUD_ADMIN_USER=ncadmin
NEXTCLOUD_ADMIN_PASSWORD=ncpassword123
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.yourdomain.com localhost
POSTGRES_HOST=postgres
REDIS_HOST=redis

# FileBrowser Configuration
FILEBROWSER_PORT=8080
FILEBROWSER_ROOT=/srv

# Network Configuration
NETWORK_NAME=storage-network

# SSL Configuration (for Traefik)
ACME_EMAIL=admin@example.com

# Backup Configuration
BACKUP_PATH=/opt/storage/backups
BACKUP_RETENTION_DAYS=30