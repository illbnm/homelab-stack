# =============================================================================
# Storage Stack — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env
# =============================================================================

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# ---------------------------------------------------------------------------
# Nextcloud (FPM + Nginx)
# ---------------------------------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Standalone database for Nextcloud (recommended if not using shared DB stack)
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NEXTCLOUD_DB_PASSWORD

# Standalone Redis for Nextcloud
NEXTCLOUD_REDIS_PASSWORD=CHANGE_ME_NEXTCLOUD_REDIS_PASSWORD

# ---------------------------------------------------------------------------
# MinIO — S3-Compatible Object Storage
# Login: https://minio.${DOMAIN}  |  API: https://s3.${DOMAIN}
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# ---------------------------------------------------------------------------
# FileBrowser — https://files.${DOMAIN}
# Default credentials: admin / admin (change after first login)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Syncthing — https://sync.${DOMAIN}
# Default credentials: syncthing / ${SYNCTHING_GUI_PASSWORD}
# ---------------------------------------------------------------------------
SYNCTHING_GUI_PASSWORD=CHANGE_ME_SYNC_GUI_PASSWORD
SYNCTHING_API_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# ---------------------------------------------------------------------------
# Shared Storage Path
# All user data goes here — mounted from host for persistence
# ---------------------------------------------------------------------------
STORAGE_PATH=/data/storage
