# =============================================================================
# Storage Stack — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# Domain (must match base infrastructure)
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Nextcloud Admin
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Database (must match databases stack's initdb passwords)
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NEXTCLOUD_DB
REDIS_PASSWORD=CHANGE_ME_REDIS

# Default phone region (ISO 3166-1 alpha-2)
DEFAULT_PHONE_REGION=CN

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# Storage paths
STORAGE_ROOT=/data/storage

# Syncthing (UID/GID of the host user running containers)
PUID=1000
PGID=1000

# SMTP (optional, for Nextcloud email notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_AUTHTYPE=LOGIN
# SMTP_USER=your@email.com
# SMTP_PASSWORD=CHANGE_ME_SMTP
# MAIL_FROM=noreply
