# =============================================================================
# Observability Stack Configuration
# =============================================================================

# Domain
DOMAIN=example.com

# Timezone
TZ=Asia/Shanghai

# Data Retention
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=168h
TEMPO_RETENTION=72h

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_password

# Grafana OIDC (Authentik)
GRAFANA_OAUTH_ENABLED=false
GRAFANA_OIDC_CLIENT_ID=
GRAFANA_OIDC_CLIENT_SECRET=

# Nextcloud Exporter (optional)
NEXTCLOUD_EXPORTER_USER=
NEXTCLOUD_EXPORTER_PASSWORD=
