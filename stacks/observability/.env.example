# Observability Stack 环境变量配置
#
# 复制为 .env 并根据实际情况修改
#
# ═══════════════════════════════════════════════════════════════════════════
# 基础环境
# ═══════════════════════════════════════════════════════════════════════════

TZ=Asia/Shanghai
DOMAIN=example.com           # 主域名 (与 Base Stack 一致)

# ═══════════════════════════════════════════════════════════════════════════
# 数据保留策略 (单位: d = 天)
# ═══════════════════════════════════════════════════════════════════════════
PROMETHEUS_RETENTION=30d     # Prometheus 指标保留 30 天
LOKI_RETENTION=7d            # Loki 日志保留 7 天
TEMPO_RETENTION=3d           # Tempo 追踪数据保留 3 天

# ═══════════════════════════════════════════════════════════════════════════
# Alertmanager 通知配置
# ═══════════════════════════════════════════════════════════════════════════
# 与 Notifications Stack 集成 (ntfy)
NTFY_TOKEN=                  # ntfy 认证 token (可选，如未启用可留空)

# 邮件通知 (可选，如未配置可注释掉 Alertmanager 中的邮件接收器)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alertmanager@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=alertmanager@${DOMAIN}

# ═══════════════════════════════════════════════════════════════════════════
# Grafana OIDC 集成 (与 SSO Stack 配合)
# ═══════════════════════════════════════════════════════════════════════════
# 使用 Authentik OIDC 登录 Grafana
GRAFANA_OAUTH_ENABLED=true
GRAFANA_OAUTH_CLIENT_ID=grafana
GRAFANA_OAUTH_CLIENT_SECRET=your-client-secret
# Authentik 会在首次使用时自动创建客户端，这些值可在 Authentik 管理界面生成

# OIDC 角色映射 (Grafana Admin/Viewer 基于 Authentik 组)
# 在 Grafana 配置中:
# GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH=groups[*]@.contains('homelab-admins') ? 'Admin' : 'Viewer'

# ═══════════════════════════════════════════════════════════════════════════
# 性能调优 (根据服务器资源调整)
# ═══════════════════════════════════════════════════════════════════════════
# Prometheus 存储大小限制
# PROMETHEUS_TSDB_RETENTION_SIZE=10GB

# Grafana 内存限制 (需在 docker-compose.yml 中调整)
# GF_MEMORY_LIMIT=512M

# Loki 压缩配置
# LOKI_COMPRESSION=gzip

# ═══════════════════════════════════════════════════════════════════════════
# 网络配置 (通常使用默认)
# ═══════════════════════════════════════════════════════════════════════════
# Prometheus 抓取间隔 (默认 15s)
# PROMETHEUS_SCRAPE_INTERVAL=15s

# Alertmanager 告警分组等待时间
# ALERTMANAGER_GROUP_WAIT=10s