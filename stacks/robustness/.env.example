# Homelab Stack #8 - Robustness 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# =============================================================================
# 基础配置
# =============================================================================

# 主域名 (用于 Traefik 反向代理)
DOMAIN=example.com

# 时区设置
TZ=Asia/Shanghai

# =============================================================================
# 国内镜像源配置
# =============================================================================

# Docker Hub 镜像加速 (选择其一)
# 阿里云 (推荐): https://cr.console.aliyun.com/cn-hangzhou/instances/mirrors
DOCKER_MIRROR_URL=https://docker.mirrors.ustc.edu.cn

# Docker Hub 备选镜像源
DOCKER_MIRROR_BACKUP1=https://registry.docker-cn.com
DOCKER_MIRROR_BACKUP2=https://hub-mirror.c.163.com

# GitHub 镜像 (可选，用于拉取 ghcr.io 镜像)
GITHUB_PROXY=https://ghproxy.com

# Google Container Registry 镜像
GCR_PROXY=https://gcr.io

# =============================================================================
# DNS 配置
# =============================================================================

# 国内 DNS 服务器 (阿里 DNS)
DNS_PRIMARY=223.5.5.5
DNS_SECONDARY=223.6.6.6

# 备用 DNS (腾讯 DNSPod)
DNS_BACKUP=119.29.29.29

# =============================================================================
# NTP 时间同步配置
# =============================================================================

# 国内 NTP 服务器
NTP_SERVER1=ntp.aliyun.com
NTP_SERVER2=ntp.tencent.com
NTP_SERVER3=cn.pool.ntp.org

# =============================================================================
# 网络健康检查配置
# =============================================================================

# 健康检查间隔 (秒)
HEALTH_CHECK_INTERVAL=60

# 连接超时时间 (秒)
CONNECT_TIMEOUT=5

# 最大重试次数
MAX_RETRIES=3

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别 (DEBUG/INFO/WARN/ERROR)
LOG_LEVEL=INFO

# 日志保留天数
LOG_RETENTION_DAYS=7

# 单个日志文件最大大小 (MB)
LOG_MAX_SIZE=10

# 日志文件最大数量
LOG_MAX_FILE=3
