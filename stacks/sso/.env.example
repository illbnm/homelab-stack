# =============================================================================
# SSO Stack — Authentik Environment Variables
# Copy to .env and fill ALL required values before running.
# =============================================================================

# Shared domain (from root .env)
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (default: auth.yourdomain.com)
AUTHENTIK_DOMAIN=auth.${DOMAIN}

# REQUIRED: Generate with: openssl rand -base64 32
AUTHENTIK_SECRET_KEY=

# REQUIRED: Strong random passwords
AUTHENTIK_POSTGRES_PASSWORD=
AUTHENTIK_REDIS_PASSWORD=

# Bootstrap admin account (created on first boot via initial-setup flow)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@yourdomain.com
AUTHENTIK_BOOTSTRAP_PASSWORD=

# Bootstrap API token (for setup-authentik.sh script)
# Generate with: openssl rand -hex 32
AUTHENTIK_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------------------------
# SMTP / Email Backend
# Used for: password reset emails, user invitation emails, notifications
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=authentik@yourdomain.com
SMTP_PASSWORD=
SMTP_FROM=authentik@yourdomain.com
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# OIDC / OAuth2 Client Credentials
# Auto-filled by ../../scripts/setup-authentik.sh
# ---------------------------------------------------------------------------

# Grafana — OIDC
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=

# Gitea — OIDC
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=

# Outline — OIDC
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=

# Bookstack — OIDC
BOOKSTACK_OIDC_CLIENT_ID=
BOOKSTACK_OIDC_CLIENT_SECRET=

# Nextcloud — OIDC (social login)
NEXTCLOUD_OIDC_CLIENT_ID=
NEXTCLOUD_OIDC_CLIENT_SECRET=

# Open WebUI — OIDC
OPEN_WEBUI_OIDC_CLIENT_ID=
OPEN_WEBUI_OIDC_CLIENT_SECRET=

# Jellyseerr — OIDC
JELLYSEERR_OIDC_CLIENT_ID=
JELLYSEERR_OIDC_CLIENT_SECRET=

# Portainer — OAuth
PORTAINER_OAUTH_CLIENT_ID=
PORTAINER_OAUTH_CLIENT_SECRET=

# Traefik ForwardAuth Proxy Provider
# Created by setup-authentik.sh — used by authentik-outpost container
AUTHENTIK_OUTPOST_CLIENT_ID=
AUTHENTIK_OUTPOST_CLIENT_SECRET=
