# =============================================================================
# SSO Stack — Environment Variables
# Copy to .env and fill ALL required values before running.
# =============================================================================

# ---------------------------------------------------------------------------
# 基础配置
# ---------------------------------------------------------------------------

# 共享域名（与根目录 .env 相同）
DOMAIN=yourdomain.com

# 时区
TZ=Asia/Shanghai

# Authentik 访问域名（默认: auth.yourdomain.com）
AUTHENTIK_DOMAIN=auth.${DOMAIN}

# ---------------------------------------------------------------------------
# 密钥和密码（必须填写）
# ---------------------------------------------------------------------------

# Authentik 密钥（生成方法: openssl rand -base64 32）
AUTHENTIK_SECRET_KEY=

# PostgreSQL 密码（生成方法: openssl rand -hex 16）
AUTHENTIK_POSTGRES_PASSWORD=

# Redis 密码（生成方法: openssl rand -hex 16）
AUTHENTIK_REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# 管理员账号（首次启动时自动创建）
# ---------------------------------------------------------------------------

AUTHENTIK_BOOTSTRAP_EMAIL=admin@yourdomain.com
AUTHENTIK_BOOTSTRAP_PASSWORD=

# ---------------------------------------------------------------------------
# API Token（setup-authentik.sh 脚本需要）
# 获取方法：登录 Authentik Web UI → Settings → Token → Create Token
# ---------------------------------------------------------------------------
AUTHENTIK_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------------------------
# OAuth2/OIDC 客户端凭证
# 由 scripts/setup-authentik.sh 自动填充，无需手动填写
# ---------------------------------------------------------------------------

# Grafana OIDC
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=

# Gitea OIDC（通过 Web UI 配置）
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=

# Outline OIDC
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=

# Portainer OAuth/OIDC
PORTAINER_OAUTH_CLIENT_ID=
PORTAINER_OAUTH_CLIENT_SECRET=

# Nextcloud OIDC（Social Login App）
NEXTCLOUD_OAUTH_CLIENT_ID=
NEXTCLOUD_OAUTH_CLIENT_SECRET=

# Open WebUI OIDC
OPEN_WEBUI_OAUTH_CLIENT_ID=
OPEN_WEBUI_OAUTH_CLIENT_SECRET=

# BookStack OIDC（可选）
BOOKSTACK_OIDC_CLIENT_ID=
BOOKSTACK_OIDC_CLIENT_SECRET=
