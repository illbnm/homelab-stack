# SSO Stack - Authentik 环境变量配置示例
#
# 复制为 .env 并填写实际值
# 重要: 生产环境请使用强随机密码!

# ═══════════════════════════════════════════════════════════════════════════
# 基础环境
# ═══════════════════════════════════════════════════════════════════════════

TZ=Asia/Shanghai
DOMAIN=auth.example.com  # 改为你的域名

# ═══════════════════════════════════════════════════════════════════════════
# Authentik 核心配置
# ═══════════════════════════════════════════════════════════════════════════

# 随机生成的密钥 (用于加密等)
# 生成方法: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=your-secret-key-here

# 管理员账户 (首次启动时自动创建)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=your-admin-password

# 可选: 初始 token (用于 API 访问)
AUTHENTIK_BOOTSTRAP_TOKEN=your-bootstrap-token-here

# ═══════════════════════════════════════════════════════════════════════════
# 数据库配置
# ═══════════════════════════════════════════════════════════════════════════

AUTHENTIK_DB_PASSWORD=your-db-password

# ═══════════════════════════════════════════════════════════════════════════
# 可选: 电子邮件配置 (SMTP)
# ═══════════════════════════════════════════════════════════════════════════

# 如果不需要邮件功能，可留空

# AUTHENTIK_EMAIL_HOST=smtp.example.com
# AUTHENTIK_EMAIL_PORT=587
# AUTHENTIK_EMAIL_HOST_USER=admin@example.com
# AUTHENTIK_EMAIL_HOST_PASSWORD=your-email-password
# AUTHENTIK_EMAIL_USE_TLS=true
# AUTHENTIK_EMAIL_FROM=Authentik <admin@example.com>

# ═══════════════════════════════════════════════════════════════════════════
# 可选: 日志级别
# ═══════════════════════════════════════════════════════════════════════════

# 可选: debug, info, warning, error
# AUTHENTIK_LOG_LEVEL=info