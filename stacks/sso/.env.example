# Authentik SSO Configuration

# Domain Configuration
AUTHENTIK_DOMAIN=auth.yourdomain.com
AUTHENTIK_PROTOCOL=https
AUTHENTIK_INSECURE=false

# Database Configuration
POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=authentik-postgresql
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=authentik-redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# Authentik Core Settings
AUTHENTIK_SECRET_KEY=your-very-long-secret-key-minimum-50-chars-recommended
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_DISABLE_UPDATE_CHECK=false
AUTHENTIK_DISABLE_STARTUP_ANALYTICS=true
AUTHENTIK_AVATARS=initials

# Email/SMTP Configuration
AUTHENTIK_EMAIL__HOST=smtp.gmail.com
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=your-email@gmail.com
AUTHENTIK_EMAIL__PASSWORD=your-app-password
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__TIMEOUT=10
AUTHENTIK_EMAIL__FROM=noreply@yourdomain.com

# Logging
AUTHENTIK_LOG_LEVEL=info
AUTHENTIK_LOG_FILE=/dev/stdout

# Worker Configuration
AUTHENTIK_WORKER_CONCURRENCY=2

# GeoIP Configuration (optional)
AUTHENTIK_GEOIP=/geoip/GeoLite2-City.mmdb

# Outpost Settings
AUTHENTIK_OUTPOSTS__DISCOVER=true
AUTHENTIK_OUTPOSTS__CONTAINER_IMAGE_BASE=ghcr.io/goauthentik/%(type)s:%(version)s

# Default Admin User (only used on first startup)
AUTHENTIK_BOOTSTRAP_PASSWORD=your-initial-admin-password
AUTHENTIK_BOOTSTRAP_TOKEN=your-initial-api-token
AUTHENTIK_BOOTSTRAP_EMAIL=admin@yourdomain.com

# Security Headers
AUTHENTIK_WEB__LOADBALANCER=traefik
