# Authentik SSO Stack Environment Configuration

# Database Configuration
POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=your_secure_db_password_here_change_me

# Authentik Secret Key (Generate with: openssl rand -hex 50)
AUTHENTIK_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_50

# Domain Configuration
AUTHENTIK_DOMAIN=auth.yourdomain.com
AUTHENTIK_PROTOCOL=https

# Error Reporting (optional)
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# Email Configuration (SMTP)
AUTHENTIK_EMAIL__HOST=smtp.gmail.com
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=your-email@gmail.com
AUTHENTIK_EMAIL__PASSWORD=your_app_password
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__FROM=noreply@yourdomain.com

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here_change_me

# PostgreSQL External Access (for debugging, optional)
POSTGRES_PORT=5432

# Authentik Bootstrap Configuration
AUTHENTIK_BOOTSTRAP_PASSWORD=your_admin_password_here_change_me
AUTHENTIK_BOOTSTRAP_TOKEN=your_bootstrap_token_here_generate_random

# Log Level
AUTHENTIK_LOG_LEVEL=info

# Workers Configuration
AUTHENTIK_WORKERS=2

# Media and Static Files
AUTHENTIK_MEDIA_ROOT=/media
AUTHENTIK_TEMPLATES_ROOT=/templates

# Cookie Domain (should match your main domain)
AUTHENTIK_COOKIE_DOMAIN=.yourdomain.com

# Default User Settings
AUTHENTIK_DEFAULT_USER_CHANGE_NAME=true
AUTHENTIK_DEFAULT_USER_CHANGE_EMAIL=true
AUTHENTIK_DEFAULT_USER_CHANGE_USERNAME=true

# Backup Configuration
POSTGRES_BACKUP_SCHEDULE=0 3 * * *
POSTGRES_BACKUP_RETENTION=7
