# =============================================================================
# SSO Stack Configuration
# =============================================================================

# Domain
DOMAIN=example.com

# Authentik
# Generate secret: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=your_secret_key_min_60_chars

# Database (dedicated PostgreSQL)
AUTHENTIK_DB_PASSWORD=your_authentik_db_password

# Bootstrap (creates admin on first run)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=your_admin_password
AUTHENTIK_BOOTSTRAP_TOKEN=your_bootstrap_token

# Environment
AUTHENTIK_URL=http://localhost:9000
