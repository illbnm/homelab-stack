# Authentik SSO Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DOMAIN & NETWORK
# =============================================================================
DOMAIN=homelab.local
AUTHENTIK_SUBDOMAIN=auth
AUTHENTIK_URL=https://auth.homelab.local

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=your_super_secure_postgres_password_here
POSTGRES_HOST=authentik-db
POSTGRES_PORT=5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=authentik-redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# AUTHENTIK CORE SETTINGS
# =============================================================================
# Generate with: openssl rand -hex 50
AUTHENTIK_SECRET_KEY=your_authentik_secret_key_50_chars_long_here

# Error reporting (optional)
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_ERROR_REPORTING__ENVIRONMENT=production

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
AUTHENTIK_EMAIL__HOST=smtp.gmail.com
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=your-email@gmail.com
AUTHENTIK_EMAIL__PASSWORD=your-app-password
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__FROM=noreply@homelab.local

# =============================================================================
# OIDC PROVIDERS CONFIGURATION
# =============================================================================

# Grafana OAuth
GRAFANA_CLIENT_ID=grafana-oauth-client
GRAFANA_CLIENT_SECRET=your_grafana_client_secret_here

# Gitea OIDC
GITEA_CLIENT_ID=gitea-oidc-client
GITEA_CLIENT_SECRET=your_gitea_client_secret_here

# Outline OIDC
OUTLINE_CLIENT_ID=outline-oidc-client
OUTLINE_CLIENT_SECRET=your_outline_client_secret_here

# Open WebUI OIDC
OPENWEBUI_CLIENT_ID=openwebui-oidc-client
OPENWEBUI_CLIENT_SECRET=your_openwebui_client_secret_here

# Nextcloud OIDC
NEXTCLOUD_CLIENT_ID=nextcloud-oidc-client
NEXTCLOUD_CLIENT_SECRET=your_nextcloud_client_secret_here

# Bookstack OIDC
BOOKSTACK_CLIENT_ID=bookstack-oidc-client
BOOKSTACK_CLIENT_SECRET=your_bookstack_client_secret_here

# Portainer OAuth
PORTAINER_CLIENT_ID=portainer-oauth-client
PORTAINER_CLIENT_SECRET=your_portainer_client_secret_here

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Default admin user (will be created on first run)
AUTHENTIK_BOOTSTRAP_PASSWORD=your_admin_password_here
AUTHENTIK_BOOTSTRAP_TOKEN=your_bootstrap_token_here
AUTHENTIK_BOOTSTRAP_EMAIL=admin@homelab.local

# CSRF settings
AUTHENTIK_CSRF_TRUSTED_ORIGINS=https://auth.homelab.local

# Cookie settings
AUTHENTIK_COOKIE_DOMAIN=.homelab.local

# =============================================================================
# LOGGING & DEBUG
# =============================================================================
AUTHENTIK_LOG_LEVEL=info
AUTHENTIK_DEBUG=false

# =============================================================================
# WORKER SETTINGS
# =============================================================================
AUTHENTIK_WORKER_CONCURRENCY=2

# =============================================================================
# TRAEFIK INTEGRATION
# =============================================================================
TRAEFIK_NETWORK=homelab-traefik

# =============================================================================
# BACKUP SETTINGS
# =============================================================================
BACKUP_RETENTION_DAYS=30
