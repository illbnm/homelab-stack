# ──────────────────────────────────────────────
# Media Stack — Environment Variables
# ──────────────────────────────────────────────
# Copy to .env and edit before running:
#   cp .env.example .env && nano .env

# ── Global ────────────────────────────────────
DOMAIN=example.com
TZ=Asia/Shanghai

# ── Linux user/group IDs (run `id` to check) ──
PUID=1000
PGID=1000

# ── Data Root ─────────────────────────────────
# TRaSH Guides recommended layout — single mount
# point enables hardlinks (no copy+delete):
#
#   ${DATA_ROOT}/
#   ├── torrents/
#   │   ├── movies/
#   │   └── tv/
#   └── media/
#       ├── movies/
#       └── tv/
#
DATA_ROOT=/srv/data
