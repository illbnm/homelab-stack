# Media Stack — Environment Variables
# Copy to .env and fill in your values

# General
TZ=Europe/Berlin
DOMAIN=yourdomain.com

# User/Group IDs (run: id $(whoami) to find yours)
PUID=1000
PGID=1000

# Paths on host (must exist)
MEDIA_PATH=/opt/media       # where your movies/tv are stored
DOWNLOAD_PATH=/opt/downloads  # where downloads land
