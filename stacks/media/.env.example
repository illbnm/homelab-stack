# =============================================================================
# Media Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values
# cp .env.example .env

# -----------------------------------------------------------------------------
# 系统配置
# -----------------------------------------------------------------------------
# 用户 ID 和组 ID (Linux 权限)
PUID=1000
PGID=1000

# 时区
TZ=Asia/Shanghai

# 域名配置 (用于 Traefik 反向代理)
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# 目录配置
# -----------------------------------------------------------------------------
# 配置文件目录
CONFIG_ROOT=./config

# 缓存目录
CACHE_ROOT=./cache

# 媒体库根目录 (Jellyfin 扫描的媒体文件)
MEDIA_ROOT=/data/media

# 下载目录 (qBittorrent 下载位置)
DOWNLOADS_ROOT=/data/downloads

# -----------------------------------------------------------------------------
# 服务密码 (请修改为强密码)
# -----------------------------------------------------------------------------
# qBittorrent WebUI 密码
QB_USERNAME=admin
QB_PASSWORD=your_secure_password_here

# Jellyfin 初始管理员密码 (首次登录后建议修改)
JELLYFIN_PASSWORD=your_secure_password_here

# Jellyseerr 初始密码
JELLYSEERR_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# Traefik 配置 (可选 - 如需 HTTPS)
# -----------------------------------------------------------------------------
# Let's Encrypt 邮箱
LETSENCRYPT_EMAIL=your_email@yourdomain.com

# Authentik 认证 (可选)
AUTHENTIK_ENABLED=false
AUTHENTIK_URL=https://authentik.yourdomain.com
