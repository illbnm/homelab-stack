# Media Stack Environment Variables
# Copy to .env and configure

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
PUID=1000
PGID=1000
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# MEDIA PATHS
# -----------------------------------------------------------------------------
MEDIA_ROOT=/opt/homelab/media
DOWNLOADS_ROOT=/opt/homelab/downloads

# -----------------------------------------------------------------------------
# API KEYS
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
JELLYFIN_API_KEY=

# -----------------------------------------------------------------------------
# QBITTORRENT
# -----------------------------------------------------------------------------
# REQUIRED: Change these credentials!
QBITTORRENT_USER=admin
QBITTORRENT_PASSWORD=changeme

# -----------------------------------------------------------------------------
# CN MIRROR (for China users)
# -----------------------------------------------------------------------------
# Uncomment to use Chinese mirrors
# CN_MODE=true
