# =============================================================================
# Media Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
DOMAIN=home.example.com
PUID=1000
PGID=1000
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# Path Settings (TRaSH Guides Hardlink Structure)
# -----------------------------------------------------------------------------
# IMPORTANT: MEDIA_ROOT and DOWNLOADS_ROOT MUST be on the same filesystem
# for hardlinks to work correctly!

# Host path for organized media library
MEDIA_ROOT=/data/media

# Host path for downloads (torrents)
DOWNLOADS_ROOT=/data/torrents

# -----------------------------------------------------------------------------
# qBittorrent Settings
# -----------------------------------------------------------------------------
QBT_WEBUI_PORT=8080
QBT_TORRENTING_PORT=6881

# -----------------------------------------------------------------------------
# Traefik Middleware Configuration
# -----------------------------------------------------------------------------
# Default security headers middleware
TRAEFIK_MIDDLEWARES_DEFAULT=traefik-secured-headers@docker

# Optional: Authentik Forward Auth protection
# Uncomment and set to enable Authentik protection (requires SSO stack)
# TRAEFIK_MIDDLEWARES_AUTH=,traefik-authentik-forwardauth@docker
TRAEFIK_MIDDLEWARES_AUTH=