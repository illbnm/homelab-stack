# ===================
# 基础配置
# ===================

# 用户 ID (使用 id -u 获取)
PUID=1000

# 组 ID (使用 id -g 获取)
PGID=1000

# 时区
TZ=Asia/Shanghai

# 你的域名
DOMAIN=example.com

# ===================
# 目录配置
# ===================

# 媒体目录 (电影、剧集存放位置)
MEDIA_ROOT=/data/media

# 下载目录 (qBittorrent 下载位置)
DOWNLOADS_ROOT=/data/downloads

# ===================
# qBittorrent
# ===================

# Web UI 用户名
QB_USERNAME=admin

# Web UI 密码
QB_PASSWORD=your-secure-password

# ===================
# Jellyfin (可选)
# ===================

# Jellyfin 管理员账户
JELLYFIN_ADMIN_USER=admin
JELLYFIN_ADMIN_PASSWORD=your-jellyfin-password
