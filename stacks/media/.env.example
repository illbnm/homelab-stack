# Media Stack 环境变量配置示例
#
# 复制为 .env 并根据实际路径修改
# 使用前确保目录存在且 Jellyfin 用户有读写权限

# ═══════════════════════════════════════════════════════════════════════════
# 基础路径配置 (遵循 TRaSH Guides 硬链接最佳实践)
# ═══════════════════════════════════════════════════════════════════════════

# 下载目录 (qBittorrent 下载到这里)
DOWNLOADS_ROOT=/data/torrents

# 媒体目录 (Jellyfin 从这里读取，Sonarr/Radarr 整理后移动到这里)
MEDIA_ROOT=/data/media

# ═══════════════════════════════════════════════════════════════════════════
# 用户/组 ID (确保容器内进程有正确的文件权限)
# ═══════════════════════════════════════════════════════════════════════════

# 通常使用 host 系统的用户 ID (运行 `id -u` 查看)
PUID=1000

# 通常使用 host 系统的组 ID (运行 `id -g` 查看)
PGID=1000

# ═══════════════════════════════════════════════════════════════════════════
# 时区
# ═══════════════════════════════════════════════════════════════════════════

TZ=Asia/Shanghai

# ═══════════════════════════════════════════════════════════════════════════
# Traefik 域名 (必需)
# ═══════════════════════════════════════════════════════════════════════════

DOMAIN=example.com

# ═══════════════════════════════════════════════════════════════════════════
# 可选: 随机密码生成 (启动时会自动生成)
# 如果你想要固定密码，可以在这里设置
# ═══════════════════════════════════════════════════════════════════════════

# qBittorrent Web UI 密码 (可选，默认随机生成)
# QBITTORRENT_PASSWORD=

# Sonarr API Key (可选，默认随机生成)
# SONARR_API_KEY=

# Radarr API Key (可选，默认随机生成)
# RADARR_API_KEY=

# Jellyfin 服务器名称 (可选)
# JELLYFIN_SERVER_NAME=Mediaserver

# ═══════════════════════════════════════════════════════════════════════════
# 硬件加速配置 (如使用 GPU 转码)
# ═══════════════════════════════════════════════════════════════════════════

# Intel QuickSync (常用)
# JELLYFIN_HW_DEVICE=intel-quicksync
# JELLYFIN_HW_DEVICE_TYPE=vaapi
# JELLYFIN_VAAPI_DEVICE=/dev/dri/renderD128

# NVIDIA GPU
# JELLYFIN_HW_DEVICE=nvenc
# JELLYFIN_HW_DEVICE_TYPE=cuda
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,video,graphics

# ═══════════════════════════════════════════════════════════════════════════
# 高级配置
# ═══════════════════════════════════════════════════════════════════════════

# Sonarr 下载客户端标识 (用于在 qBittorrent 中识别)
# SONARR_DOWNLOAD_CLIENT=qBittorrent

# Radarr 下载客户端标识
# RADARR_DOWNLOAD_CLIENT=qBittorrent

# Prowlarr 索引器超时 (秒)
# PROWLARR_TIMEOUT=60