# ==================== Time & Region ====================
TZ=Asia/Shanghai

# ==================== Domain Configuration ====================
DOMAIN=localhost

# ==================== User Permissions ====================
PUID=1000
PGID=1000

# ==================== Media Paths ====================
# Following TRaSH Guides hardlink best practices:
# /data/torrents/  -> for incomplete downloads
# /data/media/     -> for finalized media (hardlinked from downloads)
MEDIA_PATH=/mnt/media
DOWNLOAD_PATH=/mnt/downloads

# ==================== API Keys (optional) ====================
# Generate Jellyfin API key from Jellyfin dashboard > API Keys
JELLYFIN_API_KEY=
