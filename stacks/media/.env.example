# =============================================================================
# Media Stack — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- General ---
TZ=Asia/Shanghai
DOMAIN=example.com
PUID=1000
PGID=1000

# --- Data Directories (TRaSH Guides hardlink structure) ---
# Single root directory containing both torrents/ and media/ subdirs.
# This enables instant hardlinks instead of slow copy+delete.
#
# Expected layout:
#   /data/
#   ├── torrents/
#   │   ├── movies/
#   │   └── tv/
#   └── media/
#       ├── movies/
#       └── tv/
#
DATA_ROOT=/data

# --- qBittorrent ---
# Port for incoming BitTorrent connections (forward in your router)
BT_PORT=6881
