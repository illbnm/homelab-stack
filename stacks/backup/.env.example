# Backup Configuration

# Backup target: local, s3, b2, sftp, r2
BACKUP_TARGET=local

# Backup directory
BACKUP_DIR=./backups

# Retention (days)
RETENTION_DAYS=7

# Restic
RESTIC_PASSWORD=change_me_secure_password

# MinIO / S3 Compatible (for S3, R2 targets)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=homelab-backups
# S3_ENDPOINT=https://s3.example.com

# Backblaze B2 (for B2 target)
# B2_KEY_ID=
# B2_KEY=
# B2_BUCKET=homelab-backups

# SFTP (for SFTP target)
# SFTP_HOST=
# SFTP_USER=
# SFTP_PASSWORD=
# SFTP_PATH=/backups

# ntfy notification
NTFY_HOST=ntfy
NTFY_PORT=80

# Domain
DOMAIN=homelab.local
