# ==================== Time & Region ====================
TZ=Asia/Shanghai

# ==================== Domain Configuration ====================
DOMAIN=localhost

# ==================== User Permissions ====================
PUID=1000
PGID=1000

# ==================== Backup Configuration ====================

# Backup target type: local, s3, b2, sftp, r2
BACKUP_TARGET=local

# Local backup directory
BACKUP_DIR=/opt/homelab-backups

# Backup retention (days)
BACKUP_RETENTION_DAYS=7

# ==================== Restic REST Server ====================
RESTIC_PASSWORD=changeme_restic_password

# ==================== S3/MinIO Configuration (if using S3 target) ====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=homelab-backups
S3_ENDPOINT=

# ==================== Backblaze B2 Configuration ====================
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
B2_BUCKET_NAME=

# ==================== SFTP Configuration ====================
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PATH=/backup

# ==================== Cloudflare R2 Configuration ====================
R2_ACCOUNT_ID=
R2_ACCOUNT_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ==================== Notification (ntfy) ====================
NTFY_URL=
NTFY_TOKEN=
