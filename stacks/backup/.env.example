# Backup Stack Configuration
# =============================================================================

# Restic REST Server
RESTIC_USERNAME=homelab
RESTIC_PASSWORD=changeme-restic
RESTIC_DATA_PATH=/opt/homelab-backups/restic

# Duplicati
BACKUP_SOURCE_PATH=/data

# Backup Targets (choose one): local, s3, b2, sftp, r2
BACKUP_TARGET=local

# S3/MinIO Configuration
BACKUP_S3_URL=s3://homelab-backups
BACKUP_S3_ACCESS_KEY=minioadmin
BACKUP_S3_SECRET_KEY=changeme-minio
BACKUP_S3_BUCKET=homelab-backups

# Backblaze B2 Configuration
BACKUP_B2_BUCKET=your-b2-bucket
BACKUP_B2_ACCOUNT_ID=your-b2-account-id
BACKUP_B2_APPLICATION_KEY=your-b2-application-key

# SFTP Configuration
BACKUP_SFTP_HOST=your-sftp-server.com
BACKUP_SFTP_PORT=22
BACKUP_SFTP_USER=backup
BACKUP_SFTP_PASSWORD=your-sftp-password
BACKUP_SFTP_PATH=/backups/homelab

# Cloudflare R2 Configuration
BACKUP_R2_BUCKET=your-r2-bucket
BACKUP_R2_ACCESS_KEY_ID=your-r2-access-key
BACKUP_R2_SECRET_ACCESS_KEY=your-r2-secret-key
BACKUP_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Backup Schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup Retention
BACKUP_RETENTION_DAYS=7

# Notification Settings
NTFY_TOPIC=homelab-backup
NTFY_SERVER=https://ntfy.sh
