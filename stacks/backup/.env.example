# =============================================================================
# Backup Stack Configuration
# =============================================================================

# Domain
DOMAIN=example.com

# Duplicati
DUPLICATI_PASSWORD=your_webui_password

# Backup Configuration
BACKUP_DIR=/var/backups/homelab
KEEP_DAYS=7

# Backup Target: local|s3|b2|sftp|r2
BACKUP_TARGET=local

# S3 (AWS)
# S3_BUCKET=your-s3-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# B2 (Backblaze)
# B2_BUCKET=your-b2-bucket
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=

# Cloudflare R2
# R2_BUCKET=your-r2-bucket
# R2_ACCESS_KEY=
# R2_SECRET_KEY=

# SFTP
# SFTP_HOST=backup.example.com
# SFTP_USER=backup
# SFTP_PATH=/backups

# Notification (ntfy)
NTFY_URL=https://ntfy.example.com
