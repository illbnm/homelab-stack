# === General ===
TZ=Asia/Shanghai
DOMAIN=home.local
PUID=1000
PGID=1000

# === Duplicati ===
DUPLICATI_PASSWORD=change_me_strong_password
DUPLICATI_CONFIG_URL=

# === Restic ===
RESTIC_PASSWORD=change_me_restic_password
RESTIC_REPO=/var/backups/restic
RESTIC_REST_USER=admin
RESTIC_REST_PASS=change_me_restic_http_pass

# === Backup Targets ===
BACKUP_TARGET=local
# Options: local | s3 | b2 | sftp | r2

# Local backup path
BACKUP_LOCAL_PATH=/mnt/backup

# S3 / MinIO
S3_ENDPOINT=
S3_BUCKET=homelab-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Backblaze B2
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
B2_BUCKET=

# SFTP
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PATH=/backups/homelab

# Cloudflare R2
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# === Encryption ===
BACKUP_ENCRYPTION_KEY=change_me_32_byte_key_here_xxxxxxxx

# === Notifications (ntfy) ===
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=homelab-backups
NTFY_PRIORITY=default

# === Retention ===
BACKUP_RETENTION_DAYS=7
