# Backup & DR Stack - 环境变量配置

# ============================================
# 备份存储配置
# ============================================
BACKUP_DIR=/backup
RETENTION_DAYS=30

# ============================================
# Restic 配置
# ============================================
RESTIC_PASSWORD=ChangeMeToAStrongPassword123!
RESTIC_REPOSITORY=/backup/restic
RESTIC_BACKUP_SOURCES=/data/workspace
RESTIC_COMPRESSION=auto
BACKUP_CRON=0 2 * * *

# ============================================
# Proxmox Backup Server 配置
# ============================================
PBS_PASSWORD=ChangeMeToAStrongPassword123!
PBS_FINGERPRINT=

# ============================================
# 数据库备份配置 (可选)
# ============================================
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=homelab

MYSQL_HOST=mysql
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password

# ============================================
# 通知配置 (可选)
# ============================================
NOTIFY_URL=
DOMAIN=your-domain.com

# ============================================
# 时区配置
# ============================================
TZ=Asia/Shanghai
