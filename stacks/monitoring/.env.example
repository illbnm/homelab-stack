# Monitoring Stack env — copy root .env, values below are stack-specific
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=
AUTHENTIK_DOMAIN=auth.yourdomain.com
DOMAIN=localhost

# Data Retention
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=7d
TEMPO_RETENTION=3d

# Uptime Kuma
UPTIME_KUMA_URL=http://uptime-kuma:3001
UPTIME_KUMA_API_KEY=

# Grafana OnCall
ONCALL_SECRET_KEY=changeme
TELEGRAM_TOKEN=
SLACK_API_TOKEN=

# Service URLs for monitoring
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200
ALERTMANAGER_URL=http://alertmanager:9093
TRAEFIK_URL=http://traefik:8080
AUTHENTIK_URL=http://authentik:8000
NEXTCLOUD_URL=http://nextcloud:8080
GITEA_URL=http://gitea:3000
