# Monitoring Stack Environment Variables

# Domain Configuration
DOMAIN=yourdomain.com
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# OAuth Configuration (from Authentik)
GRAFANA_OAUTH_CLIENT_ID=grafana
GRAFANA_OAUTH_CLIENT_SECRET=YOUR_GRAFANA_CLIENT_SECRET
GRAFANA_OAUTH_ENABLED=true

# Data Retention
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=168h
TEMPO_RETENTION=72h

# Alert Notifications
NTFY_TOPIC=homelab-alerts
PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=

# Uptime Kuma
UPTIME_KUMA_URL=http://uptime-kuma:3001
UPTIME_KUMA_ADMIN=admin
UPTIME_KUMA_PASSWORD=CHANGE_ME
