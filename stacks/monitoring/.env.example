# =============================================================================
# Observability Stack — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
DOMAIN=yourdomain.com
AUTHENTIK_DOMAIN=auth.yourdomain.com

# -----------------------------------------------------------------------------
# Grafana Configuration
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GRAFANA_OAUTH_CLIENT_ID=your-grafana-oauth-client-id
GRAFANA_OAUTH_CLIENT_SECRET=your-grafana-oauth-client-secret

# -----------------------------------------------------------------------------
# Prometheus Configuration
# -----------------------------------------------------------------------------
PROMETHEUS_RETENTION=30d

# -----------------------------------------------------------------------------
# Loki Configuration
# -----------------------------------------------------------------------------
LOKI_RETENTION=7d

# -----------------------------------------------------------------------------
# Tempo Configuration
# -----------------------------------------------------------------------------
TEMPO_RETENTION=3d

# -----------------------------------------------------------------------------
# Alertmanager Configuration
# -----------------------------------------------------------------------------
NTFY_TOPIC=homelab-alerts
NTFY_SERVER=http://ntfy:8086

# -----------------------------------------------------------------------------
# Uptime Kuma Configuration
# -----------------------------------------------------------------------------
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
UPTIME_KUMA_URL=http://uptime-kuma:3001
