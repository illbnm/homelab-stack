# Monitoring Stack — Environment Variables
# Copy to .env and fill ALL values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# OAuth2 client credentials — filled by scripts/setup-authentik.sh
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=

# Data retention periods
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=7d
TEMPO_RETENTION=3d

# Grafana OnCall
ONCALL_DB_PASSWORD=
ONCALL_SECRET_KEY=
ONCALL_TELEGRAM_TOKEN=
ONCALL_SLACK_CLIENT_ID=
ONCALL_SLACK_CLIENT_SECRET=

# Redis password (must match databases stack .env)
REDIS_PASSWORD=

# ntfy notification settings
NTFY_TOPIC=homelab-alerts
NTFY_SERVER=https://ntfy.sh
