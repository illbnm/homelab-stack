# Observability Stack Environment Variables
# Copy to .env and configure

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# DATA RETENTION
# -----------------------------------------------------------------------------
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=7d
TEMPO_RETENTION=3d

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
# REQUIRED: Change this password!
GRAFANA_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# CN MIRROR (for China users)
# -----------------------------------------------------------------------------
# Uncomment to use Chinese mirrors
# CN_MODE=true
# GCR_MIRROR=gcr.io
