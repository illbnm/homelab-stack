# =============================================================================
# Observability Stack — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Domain (shared with base stack)
# ---------------------------------------------------------------------------
DOMAIN=example.com

# ---------------------------------------------------------------------------
# Grafana Admin
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_ADMIN_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Authentik SSO Integration (required for OAuth login)
# Create an OAuth application in Authentik:
#   Settings > Applications > Create > OAuth2/OpenID Provider
#   Redirect URIs: https://grafana.example.com/login/generic_oauth
# ---------------------------------------------------------------------------
AUTHENTIK_DOMAIN=auth.example.com
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Grafana OnCall
# ---------------------------------------------------------------------------
ONCALL_SECRET_KEY=CHANGE_ME_generate_random_string
POSTGRES_USER=oncall
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ---------------------------------------------------------------------------
# Data Retention
# ---------------------------------------------------------------------------
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=7d

# ---------------------------------------------------------------------------
# Notifications (Alertmanager → ntfy)
# ---------------------------------------------------------------------------
NTFY_WEBHOOK_URL=http://ntfy:80/t/homelab-alerts
# For external ntfy.sh topics (if ntfy service not deployed locally):
# NTFY_WEBHOOK_URL=https://ntfy.sh/YOUR_TOPIC_ID

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------
TZ=Asia/Shanghai
