# Database Stack Environment Configuration
# Copy to .env and customize values for your homelab setup

#=============================================================================
# PostgreSQL Configuration
#=============================================================================

# Database credentials (change defaults for production!)
POSTGRES_PASSWORD=homelab_secure_2024
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# Connection settings
POSTGRES_PORT=5432

#=============================================================================
# MariaDB Configuration
#=============================================================================

# Root password (must be strong for production)
MARIADB_ROOT_PASSWORD=mariadb_root_2024
MARIADB_USER=homelab
MARIADB_PASSWORD=mariadb_user_2024
MARIADB_DATABASE=homelab_db

# Connection settings
MARIADB_PORT=3306

#=============================================================================
# Redis Configuration
#=============================================================================

# Redis password (leave empty for no auth in development)
REDIS_PASSWORD=redis_secure_2024

# Connection settings
REDIS_PORT=6379

#=============================================================================
# Database Management UI Configuration
#=============================================================================

# pgAdmin credentials for PostgreSQL management
PGADMIN_DEFAULT_EMAIL=admin@homelab.local
PGADMIN_DEFAULT_PASSWORD=pgadmin_secure_2024

# Redis Commander auth (optional)
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=redis_admin_2024

#=============================================================================
# Backup Configuration
#=============================================================================

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format)
BACKUP_CRON_SCHEDULE=0 2 * * *

# S3/MinIO backup destination (optional)
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=database-backups

#=============================================================================
# Network & Domain Configuration
#=============================================================================

# Traefik domain for admin UIs (adjust to your setup)
HOMELAB_DOMAIN=homelab.local

# pgAdmin subdomain
PGADMIN_SUBDOMAIN=pgadmin

# Redis Commander subdomain
REDIS_COMMANDER_SUBDOMAIN=redis

#=============================================================================
# Volume Paths (customize for your storage layout)
#=============================================================================

# Data persistence directories
POSTGRES_DATA_PATH=./data/postgres
MARIADB_DATA_PATH=./data/mariadb
REDIS_DATA_PATH=./data/redis

# Backup storage directory
BACKUP_DATA_PATH=./backups

# pgAdmin config persistence
PGADMIN_DATA_PATH=./data/pgadmin

#=============================================================================
# Security & Performance Tuning
#=============================================================================

# PostgreSQL performance settings
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=200

# MariaDB performance settings
MARIADB_INNODB_BUFFER_POOL_SIZE=512M
MARIADB_MAX_CONNECTIONS=150

# Redis memory limit
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
