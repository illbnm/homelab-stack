# PostgreSQL Configuration
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=change_me_secure_password

# Redis Configuration
REDIS_PASSWORD=change_me_redis_password

# MariaDB Configuration (Optional - for Nextcloud MySQL)
MARIADB_ROOT_PASSWORD=change_me_mariadb_password

# pgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me_pgadmin_password

# Service Database Passwords
NEXTCLOUD_DB_PASSWORD=nextcloud_secret
GITEA_DB_PASSWORD=gitea_secret
OUTLINE_DB_PASSWORD=outline_secret
AUTHENTIK_DB_PASSWORD=authentik_secret
GRAFANA_DB_PASSWORD=grafana_secret

# Domain (for Traefik)
DOMAIN=homelab.local
