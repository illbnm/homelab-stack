# =============================================================================
# HomeLab Stack - Databases Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before starting the stack.
#   cp stacks/databases/.env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Domain (used by Traefik for management UIs)
# ---------------------------------------------------------------------------
DOMAIN=example.com

# ---------------------------------------------------------------------------
# PostgreSQL - Root credentials
# ---------------------------------------------------------------------------
POSTGRES_ROOT_PASSWORD=CHANGE_ME_strong_password_here

# ---------------------------------------------------------------------------
# Redis - Auth password
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_strong_password_here

# ---------------------------------------------------------------------------
# MariaDB - Root credentials
# ---------------------------------------------------------------------------
MARIADB_ROOT_PASSWORD=CHANGE_ME_strong_password_here

# ---------------------------------------------------------------------------
# pgAdmin - Web UI credentials
# ---------------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_strong_password_here

# ---------------------------------------------------------------------------
# Redis Commander - Web UI credentials (optional, defaults to REDIS_PASSWORD)
# ---------------------------------------------------------------------------
# REDIS_COMMANDER_USER=admin
# REDIS_COMMANDER_PASSWORD=

# ---------------------------------------------------------------------------
# Per-service PostgreSQL database passwords
# These are used by init-databases.sh to create isolated DB + user per service
# ---------------------------------------------------------------------------
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_nextcloud_db_password
GITEA_DB_PASSWORD=CHANGE_ME_gitea_db_password
OUTLINE_DB_PASSWORD=CHANGE_ME_outline_db_password
AUTHENTIK_DB_PASSWORD=CHANGE_ME_authentik_db_password
GRAFANA_DB_PASSWORD=CHANGE_ME_grafana_db_password

# ---------------------------------------------------------------------------
# Per-service MariaDB database passwords
# ---------------------------------------------------------------------------
NEXTCLOUD_MARIADB_PASSWORD=CHANGE_ME_nextcloud_mariadb_password

# ---------------------------------------------------------------------------
# Backup settings (used by backup-databases.sh)
# ---------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/opt/homelab/backups/databases

# Optional: MinIO upload settings for off-site backup
# MINIO_ENDPOINT=https://minio.example.com
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=homelab-backups