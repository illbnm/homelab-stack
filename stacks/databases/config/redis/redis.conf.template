# =============================================================================
# HomeLab Stack — Redis Configuration
# =============================================================================
# This is a TEMPLATE file. The placeholder __REDIS_PASSWORD__ is replaced
# at container startup by the entrypoint command using sed.
# Do NOT put the real password in this file.
# =============================================================================

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
requirepass __REDIS_PASSWORD__

# ---------------------------------------------------------------------------
# Memory management
# ---------------------------------------------------------------------------
maxmemory 256mb
maxmemory-policy allkeys-lru

# ---------------------------------------------------------------------------
# Persistence — AOF (Append Only File)
# ---------------------------------------------------------------------------
appendonly yes
appendfsync everysec

# ---------------------------------------------------------------------------
# Persistence — RDB snapshots
# ---------------------------------------------------------------------------
save 900 1
save 300 10
save 60 10000

# ---------------------------------------------------------------------------
# Database count (DB 0–15; we use DB 0–4 for services)
#   DB 0 — Authentik
#   DB 1 — Outline
#   DB 2 — Gitea
#   DB 3 — Nextcloud
#   DB 4 — Grafana sessions
# ---------------------------------------------------------------------------
databases 16

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
bind 0.0.0.0
protected-mode yes
tcp-backlog 511
timeout 0
tcp-keepalive 300

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
loglevel notice

# ---------------------------------------------------------------------------
# Security — Disable dangerous commands
# ---------------------------------------------------------------------------
rename-command FLUSHDB ""
rename-command FLUSHALL ""
rename-command DEBUG ""
