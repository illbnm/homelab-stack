# Base Stack — Environment Variables

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# =============================================================================
# Traefik
# =============================================================================
CLOUDFLARE_API_TOKEN=CHANGE_ME_CLOUDFLARE_TOKEN
CLOUDFLARE_EMAIL=your@email.com

# =============================================================================
# Portainer
# =============================================================================
PORTAINER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# =============================================================================
# Portainer OAuth2 (filled by scripts/setup-authentik.sh)
# =============================================================================
PORTAINER_OAUTH_CLIENT_ID=
PORTAINER_OAUTH_CLIENT_SECRET=
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Portainer OAuth Configuration
PORTAINER_OAUTH_AUTO_CREATE_USER=true
PORTAINER_OAUTH_PROVIDER=Authentik
PORTAINER_OAUTH_CLIENT_ID=${PORTAINER_OAUTH_CLIENT_ID}
PORTAINER_OAUTH_CLIENT_SECRET=${PORTAINER_OAUTH_CLIENT_SECRET}
PORTAINER_OAUTH_AUTH_URL=https://${AUTHENTIK_DOMAIN}/application/o/authorize/
PORTAINER_OAUTH_TOKEN_URL=https://${AUTHENTIK_DOMAIN}/application/o/token/
PORTAINER_OAUTH_USER_INFO_URL=https://${AUTHENTIK_DOMAIN}/application/o/userinfo/
PORTAINER_OAUTH_REDIRECT_URL=https://portainer.${DOMAIN}/
PORTAINER_OAUTH_EMAIL_CLAIM=email
PORTAINER_OAUTH_USERNAME_CLAIM=preferred_username
PORTAINER_OAUTH_NAME_CLAIM=name
