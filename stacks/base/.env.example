# Base Infrastructure Stack — Environment Variables
# Copy to .env and fill required values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# --- Traefik ---
# ACME email for Let's Encrypt certificates
ACME_EMAIL=admin@yourdomain.com
# Dashboard BasicAuth (generate with: htpasswd -nb admin PASSWORD)
# Then escape $ → $$ for Docker Compose
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$$apr1$$xxxxxx$$xxxxxx

# --- Portainer ---
# No env vars needed — admin password set on first login (within 5 minutes)

# --- Watchtower ---
# Cron schedule for auto-updates (default: daily at 4 AM)
WATCHTOWER_SCHEDULE=0 0 4 * * *
