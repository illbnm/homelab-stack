# =============================================================================
# Base Infrastructure Stack — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
DOMAIN=yourdomain.com          # Your base domain (e.g. home.example.com)

# -----------------------------------------------------------------------------
# TRAEFIK
# -----------------------------------------------------------------------------
ACME_EMAIL=you@example.com     # Let's Encrypt notification email
TRAEFIK_DASHBOARD_USER=admin
# Generate password hash: htpasswd -nbB admin 'yourpassword' > ../../config/traefik/dynamic/.htpasswd

# -----------------------------------------------------------------------------
# WATCHTOWER NOTIFICATIONS (optional)
# Integrate with Notifications Stack (Gotify/ntfy)
# Examples:
#   - Gotify: gotify://gotify-server:8080/TOKEN
#   - ntfy: ntfy://ntfy-server:80/topic
#   - Email: smtp://user:pass@host:port/from/to
# -----------------------------------------------------------------------------
WATCHTOWER_NOTIFICATION_URL=
