# Base Infrastructure Stack 环境变量配置示例
#
# 复制为 .env 并根据实际情况修改
#
# ═══════════════════════════════════════════════════════════════════════════
# 基础环境
# ═══════════════════════════════════════════════════════════════════════════

TZ=Asia/Shanghai
DOMAIN=example.com           # 你的主域名
ACME_EMAIL=admin@example.com # Let's Encrypt 注册邮箱（用于证书过期通知）

# ═══════════════════════════════════════════════════════════════════════════
# Traefik 认证
# ═══════════════════════════════════════════════════════════════════════════
# Dashboard 访问账号密码
# 生成方法: htpasswd -nb admin password | base64
TRAEFIK_USER=admin
TRAEFIK_PASSWORD=changeme
TRAEFIK_BASIC_AUTH_HASH=YWRtaW46JGFwcGxmOyQkOV5bWfp6TkRHaHF2R3R6Igo=  # admin:changeme

# ═══════════════════════════════════════════════════════════════════════════
# Portainer 配置
# ═══════════════════════════════════════════════════════════════════════════
# Portainer 管理员密码（可选，如不设置首次启动时创建）
# PORTAINER_ADMIN_PASSWORD=

# Edge 配置（用于 Portainer Agent 模式，通常不需要）
# EDGE_ID=portainer
# EDGE_KEY=changeme

# ═══════════════════════════════════════════════════════════════════════════
# Watchtower 配置
# ═══════════════════════════════════════════════════════════════════════════
# 更新检查间隔（秒，默认 300）
# WATCHTOWER_POLL_INTERVAL=300

# 定时更新计划（Cron 表达式，默认每天 3 点）
# WATCHTOWER_SCHEDULE=0 3 * * *

# 是否清理旧镜像
# WATCHTOWER_CLEANUP=true

# 通知配置（与 Notifications Stack 集成）
# WATCHTOWER_NOTIFICATION_URL=https://ntfy.${DOMAIN}/watchtower
# WATCHTOWER_NOTIFICATIONS=email
# WATCHTOWER_NOTIFICATION_TEMPLATE={{println "{{ .Count }} containers updated on {{ .Now }}"}}

# ═══════════════════════════════════════════════════════════════════════════
# DNS Challenge（可选 - 通配符证书）
# ═══════════════════════════════════════════════════════════════════════════
# 如果需要 *.example.com 通配符证书，必须使用 DNS-01 验证
# 注释掉 traefik.yml 中的 httpChallenge，启用 dnsChallenge

# 支持的 provider: cloudflare, digitalocean, route53, azure, googlecloud, etc.
# DNS_PROVIDER=cloudflare

# Cloudflare 示例:
# CF_API_EMAIL=your-email@example.com
# CF_API_KEY=your-global-api-key

# ═══════════════════════════════════════════════════════════════════════════
# 日志级别（可选）
# ═══════════════════════════════════════════════════════════════════════════
# TRAEFIK_LOG_LEVEL=INFO  # DEBUG, INFO, WARN, ERROR