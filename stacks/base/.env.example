# Base Stack - Environment Variables
# Copy to .env and fill ALL values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Portainer OAuth (Authentik)
PORTAINER_OAUTH_CLIENT_ID=
PORTAINER_OAUTH_CLIENT_SECRET=
PORTAINER_OAUTH_ISSUER_URL=https://auth.yourdomain.com/application/o/portainer/
PORTAINER_OAUTH_AUTH_URL=https://auth.yourdomain.com/application/o/authorize/
PORTAINER_OAUTH_TOKEN_URL=https://auth.yourdomain.com/application/o/token/
PORTAINER_OAUTH_USERINFO_URL=https://auth.yourdomain.com/application/o/userinfo/
PORTAINER_OAUTH_LOGOUT_URL=https://auth.yourdomain.com/application/o/portainer/end-session/
