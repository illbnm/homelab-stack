# Base Stack — Environment Variables
# Copy to .env and fill ALL values before running.

DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# Authentik domain (from SSO stack)
AUTHENTIK_DOMAIN=auth.yourdomain.com

# Traefik dashboard basic auth
# Generate with: htpasswd -nb admin password
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xxxxxx

# Portainer OAuth credentials — filled by scripts/setup-authentik.sh
PORTAINER_OAUTH_CLIENT_ID=
PORTAINER_OAUTH_CLIENT_SECRET=

# Let's Encrypt email (required for TLS certificates)
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Cloudflare API token (if using Cloudflare DNS challenge)
# CF_DNS_API_TOKEN=
