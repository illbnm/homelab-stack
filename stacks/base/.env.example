# =============================================================================
# HomeLab Stack — Base Infrastructure Environment Variables
# Copy to .env: cp .env.example .env
# Then edit with your actual values before running docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------

# Timezone (affects log timestamps and Watchtower schedule)
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Shanghai

# Host user IDs (for file permission consistency)
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# DOMAIN — Your base domain. All services use subdomains of this.
#
# Examples:
#   DOMAIN=home.example.com   → traefik.home.example.com, portainer.home.example.com
#   DOMAIN=example.com        → traefik.example.com, portainer.example.com
# -----------------------------------------------------------------------------
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# TRAEFIK — Reverse Proxy + Auto HTTPS
# -----------------------------------------------------------------------------

# Email for Let's Encrypt certificate notifications and recovery
ACME_EMAIL=you@example.com

# Traefik Dashboard Basic Auth credentials
# Generate with: echo $(htpasswd -nb admin yourpassword) | sed -e s/\$/\$\$/g
# Example result: admin:$$apr1$$xyz...
# Note: $$ is required for docker-compose (escapes the $ in hash)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# DNS CHALLENGE (optional — required for wildcard certs only)
# Leave blank if using HTTP Challenge (default)
# -----------------------------------------------------------------------------

# Cloudflare DNS Challenge
# CF_API_EMAIL=you@example.com
# CF_DNS_API_TOKEN=your_cloudflare_api_token_with_zone_edit_permission

# DigitalOcean DNS Challenge
# DO_AUTH_TOKEN=your_digitalocean_api_token

# Route53 DNS Challenge
# AWS_ACCESS_KEY_ID=your_aws_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# WATCHTOWER — Automated Container Updates
# -----------------------------------------------------------------------------

# API token for Watchtower HTTP API (used for webhook triggers)
# Generate: openssl rand -hex 16
WATCHTOWER_API_TOKEN=changeme-replace-with-random-token

# Notification URL (Shoutrrr format — integrates with Notifications Stack)
# Examples:
#   gotify://gotify.yourdomain.com/TOKEN
#   ntfy://ntfy.yourdomain.com/TOPIC
# Leave blank to disable notifications
WATCHTOWER_NOTIFICATION_URL=

# -----------------------------------------------------------------------------
# PORTAINER — Docker Management UI
# No config needed here — admin password is set on first login.
# Access: https://portainer.${DOMAIN}
# Important: Set your admin password within 5 minutes of first launch.
# -----------------------------------------------------------------------------
