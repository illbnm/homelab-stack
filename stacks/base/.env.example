# ─────────────────────────────────────────────────────────
# Base Infrastructure Stack — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Your primary domain (all subdomains will be auto-configured)
DOMAIN=example.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# Traefik Dashboard Basic Auth
# Generate with: echo $(htpasswd -nb admin yourpassword) | sed -e 's/\$/\$\$/g'
TRAEFIK_AUTH=admin:$$apr1$$xyz$$hashedpassword

# Timezone
TZ=Asia/Shanghai

# Watchtower notifications (optional)
# Supports ntfy, Slack, Discord, email, etc. via Shoutrrr URL format
# Examples:
#   ntfy:  ntfy://ntfy.sh/your-topic
#   email: smtp://user:pass@smtp.example.com/?to=you@example.com
#   Telegram: telegram://botToken@telegram/?channels=chatID
WATCHTOWER_NOTIFICATION_URL=
