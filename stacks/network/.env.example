# =============================================================================
# Network Stack — Environment Variables
# =============================================================================

# Base
TZ=Asia/Shanghai
DOMAIN=home.example.com

# WireGuard Easy — VPN Server
# WG_HOST = your public IP or domain that resolves to your server
WG_HOST=your-public-ip-or-domain
# DNS server pushed to VPN clients (AdGuard Home = 10.8.0.1)
WG_CLIENT_DNS=10.8.0.1

# Cloudflare DDNS — Dynamic DNS
# Get API key from: https://dash.cloudflare.com/profile/api-tokens
CF_API_KEY=your-cloudflare-global-api-key
CF_API_EMAIL=your-cloudflare-email@example.com
# Comma-separated list of domains to update (leave empty for auto-detect)
# CF_DOMAINS=home.example.com,wg.example.com
# Record types to update (A, AAAA, or both)
CF_RECORD_TYPES=A,AAAA
