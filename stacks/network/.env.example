# =============================================================================
# Network Stack Configuration
# =============================================================================

# Domain
DOMAIN=example.com

# Timezone
TZ=Asia/Shanghai

# Pi-hole
PIHOLE_PASSWORD=your_admin_password
PIHOLE_THEME=default-dark
DNS_PORT=53
SERVERIP=192.168.1.10

# NTP Servers (comma separated)
NTP_SERVERS=time.cloudflare.com,time.google.com,time.windows.com
