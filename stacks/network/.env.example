# ===========================================
# Network Stack - Environment Variables
# ===========================================

# General
TZ=Asia/Shanghai
DATA_DIR=./data

# --- AdGuard Home ---
ADGUARD_PORT=3000

# --- WireGuard Easy ---
WG_HOST=vpn.example.com
WG_PORT=51820
WG_UI_PORT=51821
# Generate with: echo -n "password" | argon2 hash
WG_PASSWORD_HASH=
# Internal IP of AdGuard for DNS
ADGUARD_IP=172.20.0.2
# Set to specific subnets for split tunneling, e.g. 10.0.0.0/8, 192.168.0.0/16
WG_ALLOWED_IPS=0.0.0.0/0, ::/0

# --- Cloudflare DDNS ---
CF_DOMAINS=example.com, *.example.com
CF_PROXIED=true
# CF_API_TOKEN stored in secrets/cf_api_token

# --- Nginx Proxy Manager ---
NPM_HTTP=3080
NPM_HTTPS=3443
NPM_ADMIN=81
