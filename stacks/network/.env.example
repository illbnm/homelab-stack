TZ=Asia/Shanghai
DOMAIN=home.example.com

# =============================================================================
# AdGuard Home
# Upstream DNS: Set via AdGuard dashboard or config/adguard.yaml
# Recommended upstream: Use Unbound (stacks/network) or cloudflare/quad9 DoH
# Docs: https://adguardteam.github.io/AdGuardHome/
# =============================================================================

# =============================================================================
# WireGuard Easy
# Get your public IP/hostname and set it below.
# Generate a strong password for the Web UI:
#   openssl rand -base64 24
# Docs: https://github.com/wg-easy/wg-easy
# =============================================================================
WG_HOST=your-public-ip-or-domain.example.com
WG_EASY_PASSWORD=changeme_strong_password_here

# =============================================================================
# Nginx Proxy Manager
# Default login: admin@example.com / changeme
# CHANGE THESE IMMEDIATELY after first login!
# Docs: https://nginxproxymanager.com/
# NPM_STANDALONE_CERT=false  # Set true to manage certs via NPM instead of Traefik
# =============================================================================
