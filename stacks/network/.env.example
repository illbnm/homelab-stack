# Network Stack Configuration
# =============================================================================

# WireGuard
WG_HOST=yourdomain.com         # Your public IP or domain for WireGuard
WG_PASSWORD=changeme-wg        # WireGuard Easy web UI password
WG_PORT=51820                  # WireGuard UDP port

# Cloudflare DDNS
CF_API_TOKEN=                  # Cloudflare API token with DNS edit permissions
CF_ZONE_ID=                    # Your Cloudflare Zone ID
CF_RECORD_NAME=home            # DNS record name to update (e.g., home.yourdomain.com)

# AdGuard Home
ADGUARD_IP=10.8.0.2            # AdGuard IP in WireGuard network
