# =============================================================================
# HomeLab Stack — 环境变量示例
# 复制此文件为 .env 并填入实际值
# 警告: .env 文件包含敏感信息，永远不要提交到 Git！
# =============================================================================

# ── 基础配置 ─────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
TZ=Asia/Shanghai

# ── Traefik ──────────────────────────────────────────────────────────────────
ACME_EMAIL=admin@yourdomain.com
TRAEFIK_DASHBOARD_USER=admin
# 使用 htpasswd 生成: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_PASS=hashed_password_here

# ── Notifications — ntfy ─────────────────────────────────────────────────────
NTFY_PORT=2586
# ntfy 管理员账号（用于 Web UI 登录和创建其他用户）
NTFY_USER=admin
NTFY_PASS=change-me-strong-password
# ntfy Access Token（通过 `ntfy token add` 生成，用于服务集成）
NTFY_TOKEN=
# notify.sh 默认后端: ntfy | gotify | all
NOTIFY_BACKEND=ntfy

# ── Notifications — Gotify ───────────────────────────────────────────────────
GOTIFY_PORT=8070
GOTIFY_ADMIN_USER=admin
GOTIFY_ADMIN_PASS=change-me-strong-password
# Gotify 应用 Token（在 Gotify Web UI → Apps 中创建）
GOTIFY_TOKEN=

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=change-me-strong-password
PROMETHEUS_RETENTION=15d

# ── SSO — Authentik ──────────────────────────────────────────────────────────
AUTHENTIK_SECRET_KEY=generate-with-openssl-rand-hex-32
AUTHENTIK_POSTGRES_PASSWORD=change-me-strong-password

# ── Databases ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-password
REDIS_PASSWORD=change-me-strong-password

# ── Media ────────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000
MEDIA_DIR=/data/media
DOWNLOADS_DIR=/data/downloads

# ── Storage ──────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-strong-password
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASS=change-me-strong-password

# ── Productivity ─────────────────────────────────────────────────────────────
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASS=change-me-strong-password
VAULTWARDEN_ADMIN_TOKEN=generate-with-openssl-rand-hex-32

# ── Home Automation ──────────────────────────────────────────────────────────
HASS_TZ=Asia/Shanghai
MQTT_USER=mqtt
MQTT_PASS=change-me-strong-password
