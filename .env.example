# Homelab Notifications Stack - Environment Variables
# 复制此文件为 .env 并填写所有值

# ===========================================
# 域名配置
# ===========================================
DOMAIN=your-domain.com

# ===========================================
# ntfy 配置
# ===========================================
NTFY_BASE_URL=https://ntfy.${DOMAIN}
# 可选：上游 ntfy 服务器（用于移动端推送）
NTFY_UPSTREAM_BASE_URL=

# ===========================================
# Gotify 配置
# ===========================================
GOTIFY_ADMIN_USER=admin
GOTIFY_ADMIN_PASS=YourStrongGotifyPassword123!

# ===========================================
# Apprise 配置
# ===========================================
# Apprise 状态文件路径
APPRISE_CONFIG_PATH=/config/apprise.yml

# ===========================================
# 通知集成配置
# ===========================================
# Alertmanager ntfy webhook URL
ALERTMANAGER_NTFY_URL=http://ntfy:80/homelab-alerts
# Watchtower Gotify URL
WATCHTOWER_GOTIFY_URL=http://gotify:80/message?token=YOUR_GOTIFY_TOKEN
# Gitea webhook URL (在 Gitea UI 中配置)
GITEA_WEBHOOK_URL=https://ntfy.${DOMAIN}/homelab-gitea
